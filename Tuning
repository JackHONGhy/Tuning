  DETECT_METHODS IPERF3_SERVER ALLOW_REMOTE_BENCH PROFILE=transit|host

地区档位 (REGION):
  asia  RTT≈65ms  factor 0.85   日/港/新/韩/国内等
  eu    RTT≈100ms factor 0.85   欧洲
  us    RTT≈150ms factor 0.82   北美/美亚
  far   RTT≈200ms factor 0.80   澳新/南美/非洲/中东等更远
  auto  公网IP地理识别 → 失败则用 ping RTT 分档 (GEO_DETECT=0 仅RTT)
EOF
}

# ---------- unit helpers ----------
# Convert rate strings like 950Mbit, 1Gbit, 100mbit, 123.4 to integer Mbit (floor)
rate_to_mbit(){
  local s="${1:-}"
  s="$(printf '%s' "${s}" | tr '[:upper:]' '[:lower:]' | tr -d ' ')"
  [[ -n "${s}" ]] || { printf ''; return 0; }

  if [[ "${s}" =~ ^([0-9]+(\.[0-9]+)?)gbit$ ]]; then
    awk -v v="${BASH_REMATCH[1]}" 'BEGIN{printf "%d", int(v*1000+0.5)}'
    return 0
  fi
  if [[ "${s}" =~ ^([0-9]+(\.[0-9]+)?)mbit$ ]]; then
    awk -v v="${BASH_REMATCH[1]}" 'BEGIN{printf "%d", int(v+0.5)}'
    return 0
  fi
  if [[ "${s}" =~ ^([0-9]+(\.[0-9]+)?)kbit$ ]]; then
    awk -v v="${BASH_REMATCH[1]}" 'BEGIN{printf "%d", int(v/1000+0.5)}'
    return 0
  fi
  if [[ "${s}" =~ ^([0-9]+(\.[0-9]+)?)bit$ ]]; then
    awk -v v="${BASH_REMATCH[1]}" 'BEGIN{printf "%d", int(v/1000000+0.5)}'
    return 0
  fi
  if [[ "${s}" =~ ^([0-9]+(\.[0-9]+)?)(mbps|mb/s|m)$ ]]; then
    awk -v v="${BASH_REMATCH[1]}" 'BEGIN{printf "%d", int(v+0.5)}'
    return 0
  fi
  if [[ "${s}" =~ ^([0-9]+(\.[0-9]+)?)(gbps|gb/s|g)$ ]]; then
    awk -v v="${BASH_REMATCH[1]}" 'BEGIN{printf "%d", int(v*1000+0.5)}'
    return 0
  fi
  if [[ "${s}" =~ ^([0-9]+(\.[0-9]+)?)$ ]]; then
    awk -v v="${BASH_REMATCH[1]}" 'BEGIN{printf "%d", int(v+0.5)}'
    return 0
  fi
  printf ''
}

mbit_to_rate(){
  local m="${1:-0}"
  if [[ -z "${m}" || "${m}" -le 0 ]]; then
    printf ''
    return 0
  fi
  printf '%sMbit' "${m}"
}

# Apply safety factor to integer Mbit → rate string
mbit_with_safety(){
  local m="${1:-0}"
  local f="${BANDWIDTH_SAFETY_FACTOR:-0.85}"
  local out
  out="$(awk -v m="${m}" -v f="${f}" 'BEGIN{
    if (m<=0) { print 0; exit }
    r=int(m*f+0.5)
    if (r<1) r=1
    print r
  }')"
  mbit_to_rate "${out}"
}

max_int(){
  local a="${1:-0}" b="${2:-0}"
  [[ "${a}" -gt "${b}" ]] && printf '%s' "${a}" || printf '%s' "${b}"
}

min_int(){
  local a="${1:-0}" b="${2:-0}"
  [[ "${a}" -lt "${b}" ]] && printf '%s' "${a}" || printf '%s' "${b}"
}

# Median of integers passed as args (ignores empty). Needs at least 1 value.
median_int(){
  local -a vals=()
  local v
  for v in "$@"; do
    [[ -n "${v}" && "${v}" =~ ^[0-9]+$ && "${v}" -gt 0 ]] || continue
    vals+=("${v}")
  done
  local n="${#vals[@]}"
  if [[ "${n}" -eq 0 ]]; then
    printf ''
    return 0
  fi
  local sorted
  sorted="$(printf '%s\n' "${vals[@]}" | sort -n)"
  local -a s=()
  while IFS= read -r v; do
    [[ -n "${v}" ]] && s+=("${v}")
  done <<<"${sorted}"
  n="${#s[@]}"
  local mid=$(( (n - 1) / 2 ))
  if [[ $((n % 2)) -eq 1 ]]; then
    printf '%s' "${s[mid]}"
  else
    # even: average of two middle, integer
    awk -v a="${s[mid]}" -v b="${s[$((mid + 1))]}" 'BEGIN{printf "%d", int((a+b)/2+0.5)}'
  fi
}

cpu_nproc(){
  local n
  n="$(nproc 2>/dev/null || getconf _NPROCESSORS_ONLN 2>/dev/null || echo 1)"
  [[ "${n}" -ge 1 ]] || n=1
  printf '%s' "${n}"
}

# 1-min load average as percent of one full core set (100 = all cores busy)
cpu_load_pct(){
  local load cores pct
  load="$(awk '{print $1}' /proc/loadavg 2>/dev/null || echo 0)"
  cores="$(cpu_nproc)"
  pct="$(awk -v l="${load}" -v c="${cores}" 'BEGIN{
    if (c<=0) c=1
    printf "%d", int((l/c)*100+0.5)
  }')"
  printf '%s' "${pct}"
}

# Soft max Mbit by CPU cores when CPU_CAP_RATES=1 and no MAX_* set
cpu_soft_max_mbit(){
  local cores
  cores="$(cpu_nproc)"
  if [[ "${cores}" -le 1 ]]; then
    printf '800'
  elif [[ "${cores}" -eq 2 ]]; then
    printf '3000'
  elif [[ "${cores}" -eq 3 ]]; then
    printf '5000'
  else
    printf '10000'
  fi
}

# Cap integer Mbit by MAX_* and optional CPU soft cap → print Mbit or empty
cap_mbit(){
  local m="${1:-}" which="${2:-both}" # up|down|both
  [[ -n "${m}" && "${m}" -gt 0 ]] || { printf ''; return 0; }
  local cap="" soft=""
  case "${which}" in
    up) cap="$(rate_to_mbit "${MAX_UP_RATE:-}")" ;;
    down) cap="$(rate_to_mbit "${MAX_DOWN_RATE:-}")" ;;
    *) cap="$(rate_to_mbit "${MAX_RATE:-}")" ;;
  esac
  if [[ -z "${cap}" || "${cap}" -le 0 ]]; then
    if [[ "${CPU_CAP_RATES}" == "1" ]]; then
      soft="$(cpu_soft_max_mbit)"
      cap="${soft}"
    fi
  fi
  if [[ -n "${cap}" && "${cap}" -gt 0 && "${m}" -gt "${cap}" ]]; then
    log "  rate cap: ${m} → ${cap} Mbit (${which})"
    m="${cap}"
  fi
  printf '%s' "${m}"
}

# Apply safety factor then caps → rate string
mbit_to_suggest(){
  local m="$1" which="${2:-both}"
  m="$(cap_mbit "${m}" "${which}")"
  [[ -n "${m}" ]] || { printf ''; return 0; }
  mbit_with_safety "${m}"
}

# CPU-aware ingress: high load → disable IFB ingress shaping
maybe_adjust_ingress_for_cpu(){
  [[ "${INGRESS_USER_SET}" -eq 1 ]] && {
    log "ENABLE_INGRESS_SHAPING set by user (${ENABLE_INGRESS_SHAPING}); skip CPU auto-toggle"
    return 0
  }
  local cores loadpct
  cores="$(cpu_nproc)"
  loadpct="$(cpu_load_pct)"
  log "CPU: cores=${cores} load≈${loadpct}% (off≥${CPU_INGRESS_OFF_LOAD}% on≤${CPU_INGRESS_ON_LOAD}%)"

  if [[ "${cores}" -eq 1 && "${ENABLE_INGRESS_SHAPING}" == "1" && "${loadpct}" -ge 50 ]]; then
    warn "1-core host under load → disabling ingress shaping (egress CAKE kept)"
    ENABLE_INGRESS_SHAPING=0
    return 0
  fi
  if [[ "${loadpct}" -ge "${CPU_INGRESS_OFF_LOAD}" && "${ENABLE_INGRESS_SHAPING}" == "1" ]]; then
    warn "CPU load ${loadpct}% ≥ ${CPU_INGRESS_OFF_LOAD}% → disable ingress"
    ENABLE_INGRESS_SHAPING=0
  elif [[ "${loadpct}" -le "${CPU_INGRESS_ON_LOAD}" && "${ENABLE_INGRESS_SHAPING}" == "0" ]]; then
    # only auto re-enable if not user-forced off permanently — we default was 1
    log "CPU load ${loadpct}% ≤ ${CPU_INGRESS_ON_LOAD}% → enable ingress"
    ENABLE_INGRESS_SHAPING=1
  fi
}

# Quiet HTTP GET (short timeout); print body or empty
http_get_quiet(){
  local url="$1" t="${2:-3}"
  if have_bin curl; then
    curl -fsS --max-time "${t}" -A 'bbr-cake-transit/3.4' "${url}" 2>/dev/null || true
  elif have_bin wget; then
    wget -qO- --timeout="${t}" --user-agent='bbr-cake-transit/3.4' "${url}" 2>/dev/null || true
  fi
}

# Map ISO country code → profile: asia | eu | us | far
country_to_region(){
  local cc
  cc="$(printf '%s' "${1:-}" | tr '[:lower:]' '[:upper:]')"
  [[ -n "${cc}" ]] || { printf ''; return 0; }
  case "${cc}" in
    CN|HK|MO|TW|JP|KR|SG|MY|TH|VN|PH|ID|IN|BD|PK|LK|KH|LA|MM|BN|MN|NP|BT)
      printf 'asia' ;;
    DE|FR|NL|GB|UK|IE|BE|LU|CH|AT|IT|ES|PT|SE|NO|DK|FI|PL|CZ|SK|HU|RO|BG|GR|HR|SI|RS|UA|RU|TR|IS|EE|LV|LT|MD|AL|MK|BA|ME|XK)
      printf 'eu' ;;
    US|CA|MX|PR|VI)
      printf 'us' ;;
    AU|NZ|FJ|PG|BR|AR|CL|CO|PE|UY|PY|BO|EC|VE|ZA|NG|EG|KE|MA|GH|TZ|ET|AE|SA|QA|KW|BH|OM|IL|IQ|IR|JO)
      printf 'far' ;;
    *)
      printf '' ;;
  esac
}

# Cloudflare / edge colo code → profile (reflects network location better than whois)
colo_to_region(){
  local c
  c="$(printf '%s' "${1:-}" | tr '[:lower:]' '[:upper:]')"
  [[ -n "${c}" ]] || { printf ''; return 0; }
  case "${c}" in
    # Asia-Pacific
    HKG|HKG1|NRT|KIX|ICN|SIN|TPE|BKK|MNL|CGK|BOM|DEL|MAA|HYD|KUL|HAN|SGN|PNH|RGN|UBN|ALA|TAS)
      printf 'asia' ;;
    # North America
    LAX|SJC|SFO|SEA|PDX|LAS|PHX|SAN|DEN|SLC|DFW|IAH|ORD|MDW|ATL|MIA|EWR|JFK|IAD|BOS|PHL|CLT|MSP|DTW|YUL|YYZ|YVR|SEA|BUF|CMH|IND|MCI|STL|BNA|AUS|SMF|OAK|BUR)
      printf 'us' ;;
    # Europe
    FRA|AMS|LHR|CDG|MAD|BCN|MXP|FCO|ZRH|VIE|ARN|OSL|CPH|HEL|WAW|PRG|BUD|OTP|SOF|ATH|DUB|MAN|BRU|LIS|TXL|MUC|STR|HAM)
      printf 'eu' ;;
    # Oceania / SA / ME / AF
    SYD|MEL|AKL|PER|BNE|GRU|GIG|EZE|SCL|LIM|BOG|MEX|DFW|DXB|DOH|JNB|CPT|CAI|LOS|NBO)
      # DFW already us; keep far for true remote colos
      case "${c}" in
        SYD|MEL|AKL|PER|BNE|GRU|GIG|EZE|SCL|LIM|BOG|DXB|DOH|JNB|CPT|CAI|LOS|NBO) printf 'far' ;;
        *) printf 'us' ;;
      esac
      ;;
    *)
      printf '' ;;
  esac
}

# Cloud provider placement region string → profile
cloud_code_to_region(){
  local r
  r="$(printf '%s' "${1:-}" | tr '[:upper:]' '[:lower:]')"
  [[ -n "${r}" ]] || { printf ''; return 0; }
  case "${r}" in
    na-*|us-*|ca-central*|northamerica*|america*)
      printf 'us' ;;
    eu-*|europe*)
      printf 'eu' ;;
    ap-hongkong*|ap-guangzhou*|ap-shanghai*|ap-beijing*|ap-singapore*|ap-tokyo*|ap-seoul*|ap-mumbai*|ap-bangkok*|ap-jakarta*|ap-taipei*|ap-northeast*|ap-southeast*|ap-east*|ap-south*|cn-*|asia*)
      printf 'asia' ;;
    sa-*|af-*|me-*|oc-*|au-*|australia*|southamerica*)
      printf 'far' ;;
    *)
      # substring hints
      if printf '%s' "${r}" | grep -qiE 'hongkong|singapore|tokyo|seoul|shanghai|beijing|mumbai'; then
        printf 'asia'
      elif printf '%s' "${r}" | grep -qiE 'virginia|ohio|oregon|california|silicon|ashburn|toronto|dallas|chicago'; then
        printf 'us'
      elif printf '%s' "${r}" | grep -qiE 'frankfurt|ireland|london|paris|stockholm|milan'; then
        printf 'eu'
      else
        printf ''
      fi
      ;;
  esac
}

# 1) Cloud metadata (Tencent / AWS / GCP / Azure) — most reliable for real VPS region
detect_cloud_metadata_region(){
  local body="" code="" prof="" src=""

  # Tencent Cloud (CVM / Lighthouse) — hostname VM-xxxx often Tencent
  for path in \
    'http://metadata.tencentyun.com/latest/meta-data/placement/region' \
    'http://metadata.tencentyun.com/meta-data/placement/region' \
    'http://metadata.tencentyun.com/latest/meta-data/region' \
    ; do
    body="$(http_get_quiet "${path}" 2)"
    body="$(printf '%s' "${body}" | tr -d '\r\n' | head -c 80)"
    if [[ -n "${body}" && "${body}" != *"404"* && "${body}" != *"html"* ]]; then
      code="${body}"
      src="tencent-metadata"
      break
    fi
  done

  # AWS
  if [[ -z "${code}" ]]; then
    body="$(http_get_quiet 'http://169.254.169.254/latest/meta-data/placement/region' 2)"
    body="$(printf '%s' "${body}" | tr -d '\r\n' | head -c 80)"
    if [[ -n "${body}" && "${body}" =~ ^[a-z]{2}- ]]; then
      code="${body}"
      src="aws-metadata"
    fi
  fi

  # GCP
  if [[ -z "${code}" ]]; then
    if have_bin curl; then
      body="$(curl -fsS --max-time 2 -H 'Metadata-Flavor: Google' \
        'http://metadata.google.internal/computeMetadata/v1/instance/zone' 2>/dev/null || true)"
    fi
    body="$(printf '%s' "${body}" | tr -d '\r\n')"
    if [[ -n "${body}" ]]; then
      code="${body##*/}"
      src="gcp-metadata"
    fi
  fi

  # Azure
  if [[ -z "${code}" ]]; then
    if have_bin curl; then
      body="$(curl -fsS --max-time 2 -H 'Metadata:true' \
        'http://169.254.169.254/metadata/instance/compute/location?api-version=2021-02-01&format=text' 2>/dev/null || true)"
    fi
    body="$(printf '%s' "${body}" | tr -d '\r\n')"
    if [[ -n "${body}" && "${#body}" -lt 40 ]]; then
      code="${body}"
      src="azure-metadata"
    fi
  fi

  [[ -n "${code}" ]] || return 1
  prof="$(cloud_code_to_region "${code}")"
  [[ -n "${prof}" ]] || return 1
  DETECTED_REGION="${prof}"
  DETECTED_GEO="cloud:${src} region=${code}"
  DETECTED_COUNTRY=""
  log "Cloud metadata [${src}]: ${code} → profile=${prof}"
  return 0
}

# 2) Cloudflare nearest colo from THIS server (network location)
detect_cf_colo_region(){
  local body="" colo="" prof=""
  body="$(http_get_quiet 'https://www.cloudflare.com/cdn-cgi/trace' 3)"
  [[ -z "${body}" ]] && body="$(http_get_quiet 'https://1.1.1.1/cdn-cgi/trace' 3)"
  [[ -n "${body}" ]] || return 1
  colo="$(printf '%s\n' "${body}" | awk -F= '/^colo=/{print $2; exit}' | tr -d '\r')"
  [[ -n "${colo}" ]] || return 1
  prof="$(colo_to_region "${colo}")"
  [[ -n "${prof}" ]] || {
    log "CF colo=${colo} unmapped; ignore colo signal"
    return 1
  }
  DETECTED_REGION="${prof}"
  DETECTED_GEO="cloudflare-colo=${colo}"
  log "Cloudflare colo: ${colo} → profile=${prof} (网络出口邻近节点，通常比 IP 库准)"
  return 0
}

# 3) Multi-source IP whois vote (ipapi often wrong — do not trust alone)
detect_geoip_vote_region(){
  local body cc city org votes="" n_asia=0 n_us=0 n_eu=0 n_far=0
  local sources="" p

  # ipinfo.io
  body="$(http_get_quiet 'https://ipinfo.io/json' 4)"
  if [[ -n "${body}" ]]; then
    cc="$(printf '%s' "${body}" | grep -oE '"country"[[:space:]]*:[[:space:]]*"[A-Za-z]{2}"' | head -1 | grep -oE '[A-Za-z]{2}')"
    city="$(printf '%s' "${body}" | grep -oE '"city"[[:space:]]*:[[:space:]]*"[^"]*"' | head -1 | sed 's/.*"\([^"]*\)"/\1/')"
    org="$(printf '%s' "${body}" | grep -oE '"org"[[:space:]]*:[[:space:]]*"[^"]*"' | head -1 | sed 's/.*"\([^"]*\)"/\1/')"
    p="$(country_to_region "${cc}")"
    if [[ -n "${p}" ]]; then
      sources="${sources} ipinfo=${cc}/${city:-?}->${p}"
      case "${p}" in asia) n_asia=$((n_asia+1));; us) n_us=$((n_us+1));; eu) n_eu=$((n_eu+1));; far) n_far=$((n_far+1));; esac
    fi
  fi

  # ip-api.com
  body="$(http_get_quiet 'http://ip-api.com/json/?fields=status,country,countryCode,city,isp,query' 4)"
  if printf '%s' "${body}" | grep -q '"status"[[:space:]]*:[[:space:]]*"success"'; then
    cc="$(printf '%s' "${body}" | grep -oE '"countryCode"[[:space:]]*:[[:space:]]*"[A-Za-z]{2}"' | head -1 | grep -oE '[A-Za-z]{2}')"
    city="$(printf '%s' "${body}" | grep -oE '"city"[[:space:]]*:[[:space:]]*"[^"]*"' | head -1 | sed 's/.*"\([^"]*\)"/\1/')"
    p="$(country_to_region "${cc}")"
    if [[ -n "${p}" ]]; then
      sources="${sources} ip-api=${cc}/${city:-?}->${p}"
      case "${p}" in asia) n_asia=$((n_asia+1));; us) n_us=$((n_us+1));; eu) n_eu=$((n_eu+1));; far) n_far=$((n_far+1));; esac
    fi
  fi

  # ipapi.co (often mislabels — lower priority, still one vote)
  body="$(http_get_quiet 'https://ipapi.co/json/' 4)"
  if [[ -n "${body}" ]]; then
    cc="$(printf '%s' "${body}" | grep -oE '"country_code"[[:space:]]*:[[:space:]]*"[A-Za-z]{2}"' | head -1 | grep -oE '[A-Za-z]{2}')"
    [[ -z "${cc}" ]] && cc="$(printf '%s' "${body}" | grep -oE '"country"[[:space:]]*:[[:space:]]*"[A-Za-z]{2}"' | head -1 | grep -oE '[A-Za-z]{2}')"
    city="$(printf '%s' "${body}" | grep -oE '"city"[[:space:]]*:[[:space:]]*"[^"]*"' | head -1 | sed 's/.*"\([^"]*\)"/\1/')"
    p="$(country_to_region "${cc}")"
    if [[ -n "${p}" ]]; then
      sources="${sources} ipapi.co=${cc}/${city:-?}->${p}"
      case "${p}" in asia) n_asia=$((n_asia+1));; us) n_us=$((n_us+1));; eu) n_eu=$((n_eu+1));; far) n_far=$((n_far+1));; esac
    fi
  fi

  log "IP geo votes:${sources:- none} | asia=${n_asia} us=${n_us} eu=${n_eu} far=${n_far}"

  local winner="" max=0
  [[ "${n_asia}" -gt "${max}" ]] && { max=${n_asia}; winner=asia; }
  [[ "${n_us}" -gt "${max}" ]] && { max=${n_us}; winner=us; }
  [[ "${n_eu}" -gt "${max}" ]] && { max=${n_eu}; winner=eu; }
  [[ "${n_far}" -gt "${max}" ]] && { max=${n_far}; winner=far; }

  # need at least 1 vote; prefer clear majority (≥2) 
  [[ -n "${winner}" && "${max}" -ge 1 ]] || return 1
  DETECTED_REGION="${winner}"
  DETECTED_GEO="ip-geo-vote winner=${winner} (votes=${max})${sources}"
  DETECTED_COUNTRY=""
  log "IP geo vote → profile=${winner} (votes=${max})"
  return 0
}

# Combined auto location (priority order)
geo_detect_region(){
  DETECTED_GEO=""
  DETECTED_COUNTRY=""
  DETECTED_REGION=""
  [[ "${GEO_DETECT}" == "1" ]] || return 1

  local cloud_r="" colo_r="" vote_r=""
  local cloud_geo="" colo_geo="" vote_geo=""

  # A) cloud metadata
  if detect_cloud_metadata_region; then
    cloud_r="${DETECTED_REGION}"
    cloud_geo="${DETECTED_GEO}"
  fi

  # B) CF colo
  DETECTED_REGION=""; DETECTED_GEO=""
  if detect_cf_colo_region; then
    colo_r="${DETECTED_REGION}"
    colo_geo="${DETECTED_GEO}"
  fi

  # C) multi IP geo vote
  DETECTED_REGION=""; DETECTED_GEO=""
  if detect_geoip_vote_region; then
    vote_r="${DETECTED_REGION}"
    vote_geo="${DETECTED_GEO}"
  fi

  log "位置信号汇总: cloud=${cloud_r:-?} colo=${colo_r:-?} ip-vote=${vote_r:-?}"

  # Priority: cloud metadata > CF colo > IP vote
  # If colo and ip-vote strongly disagree, prefer colo (whois 经常错标 HK)
  if [[ -n "${cloud_r}" ]]; then
    DETECTED_REGION="${cloud_r}"
    DETECTED_GEO="${cloud_geo}"
    if [[ -n "${colo_r}" && "${colo_r}" != "${cloud_r}" ]]; then
      warn "云元数据=${cloud_r} 与 CF colo=${colo_r} 不一致；优先云元数据"
    fi
    if [[ -n "${vote_r}" && "${vote_r}" != "${cloud_r}" ]]; then
      warn "云元数据=${cloud_r} 与 IP库投票=${vote_r} 不一致；优先云元数据（IP库常误标）"
    fi
    log "最终位置: profile=${DETECTED_REGION} via cloud-metadata (${DETECTED_GEO})"
    return 0
  fi

  if [[ -n "${colo_r}" ]]; then
    DETECTED_REGION="${colo_r}"
    DETECTED_GEO="${colo_geo}"
    if [[ -n "${vote_r}" && "${vote_r}" != "${colo_r}" ]]; then
      warn "CF 网络节点=${colo_r} 与 IP库=${vote_r} 不一致；优先 Cloudflare colo（IP库把美区标成香港很常见）"
    fi
    log "最终位置: profile=${DETECTED_REGION} via cloudflare-colo (${DETECTED_GEO})"
    return 0
  fi

  if [[ -n "${vote_r}" ]]; then
    DETECTED_REGION="${vote_r}"
    DETECTED_GEO="${vote_geo}"
    warn "仅依赖 IP 地理库（可能不准）。若实际在美国请: REGION=us"
    log "最终位置: profile=${DETECTED_REGION} via ip-geo-vote only"
    return 0
  fi

  warn "所有位置信号失败；将用 RTT 回退"
  return 1
}

# Apply profile defaults: CAKE_RTT + safety factor (if not user-overridden)
# $1 = profile asia|eu|us|far
apply_region_profile(){
  local prof="$1"
  REGION_PROFILE="${prof}"
  case "${prof}" in
    asia|jp|hk|sg|cn|kr)
      REGION_PROFILE="asia"
      REGION_NOTE="亚洲中转 50–80ms 带，系数偏标准"
      [[ -z "${OVERRIDE_CAKE_RTT}" ]] && CAKE_RTT="65ms"
      if [[ -z "${OVERRIDE_BANDWIDTH_SAFETY_FACTOR}" ]]; then
        # only nudge if still generic default
        BANDWIDTH_SAFETY_FACTOR="${BANDWIDTH_SAFETY_FACTOR:-0.85}"
        # keep 0.85 for asia
        [[ "${BANDWIDTH_SAFETY_FACTOR}" == "0.85" || "${BANDWIDTH_SAFETY_FACTOR}" == "0.92" ]] && BANDWIDTH_SAFETY_FACTOR="0.85"
      fi
      ;;
    eu|europe|de|nl|uk|gb)
      REGION_PROFILE="eu"
      REGION_NOTE="欧洲中转 80–120ms 带"
      [[ -z "${OVERRIDE_CAKE_RTT}" ]] && CAKE_RTT="100ms"
      if [[ -z "${OVERRIDE_BANDWIDTH_SAFETY_FACTOR}" ]]; then
        BANDWIDTH_SAFETY_FACTOR="0.85"
      fi
      ;;
    us|na|america|ca)
      REGION_PROFILE="us"
      REGION_NOTE="北美/美亚 120–180ms 带，跨洋略保守"
      [[ -z "${OVERRIDE_CAKE_RTT}" ]] && CAKE_RTT="150ms"
      if [[ -z "${OVERRIDE_BANDWIDTH_SAFETY_FACTOR}" ]]; then
        BANDWIDTH_SAFETY_FACTOR="0.82"
      fi
      ;;
    far|oceania|sa|africa|me|long)
      REGION_PROFILE="far"
      REGION_NOTE="更远路径 180–250ms 带，更保守折扣"
      [[ -z "${OVERRIDE_CAKE_RTT}" ]] && CAKE_RTT="200ms"
      if [[ -z "${OVERRIDE_BANDWIDTH_SAFETY_FACTOR}" ]]; then
        BANDWIDTH_SAFETY_FACTOR="0.80"
      fi
      ;;
    *)
      REGION_PROFILE="unknown"
      REGION_NOTE="未知档位"
      return 1
      ;;
  esac
  log "Region profile [${REGION_PROFILE}]: CAKE_RTT=${CAKE_RTT} safety=${BANDWIDTH_SAFETY_FACTOR} — ${REGION_NOTE}"
  return 0
}

# Map measured RTT (ms number) → profile when geo unavailable
rtt_ms_to_region(){
  local ms="${1:-0}"
  ms="$(printf '%s' "${ms}" | awk '{printf "%d", $1+0}')"
  if [[ "${ms}" -le 0 ]]; then
    printf 'asia'
  elif [[ "${ms}" -lt 90 ]]; then
    printf 'asia'
  elif [[ "${ms}" -lt 140 ]]; then
    printf 'eu'
  elif [[ "${ms}" -lt 200 ]]; then
    printf 'us'
  else
    printf 'far'
  fi
}

# Full resolver: manual REGION → geo → ping RTT → keep defaults
resolve_cake_rtt(){
  resolve_region_tuning
}

resolve_region_tuning(){
  local reg="${REGION:-auto}"
  reg="$(printf '%s' "${reg}" | tr '[:upper:]' '[:lower:]')"

  # Explicit user region (not auto)
  case "${reg}" in
    asia|jp|hk|sg|cn|kr|eu|europe|de|nl|uk|gb|us|na|america|ca|far|oceania|sa|africa|me|long)
      DETECTED_REGION="${reg}"
      case "${reg}" in
        jp|hk|sg|cn|kr) DETECTED_REGION="asia" ;;
        europe|de|nl|uk|gb) DETECTED_REGION="eu" ;;
        na|america|ca) DETECTED_REGION="us" ;;
        oceania|sa|africa|me|long) DETECTED_REGION="far" ;;
      esac
      apply_region_profile "${DETECTED_REGION}"
      log "REGION=${reg} (manual) → profile=${REGION_PROFILE}"
      return 0
      ;;
  esac

  # auto: multi-signal location
  step "识别服务器位置 / 选择地区调优档位（云元数据 > CF节点 > IP库投票）"
  log "提示: IP 地理库常把美区/跨国线路误标成香港；可用 REGION=us 强制覆盖"
  if [[ "${reg}" == "auto" ]] && geo_detect_region; then
    apply_region_profile "${DETECTED_REGION}"
    if [[ -z "${OVERRIDE_CAKE_RTT}" ]]; then
      local rtt_s rtt_ms prof_ms
      rtt_s="$(suggest_rtt_from_ping 1.1.1.1 || true)"
      if [[ -n "${rtt_s}" ]]; then
        rtt_ms="$(printf '%s' "${rtt_s}" | grep -oE '[0-9]+' | head -1)"
        prof_ms="$(printf '%s' "${CAKE_RTT}" | grep -oE '[0-9]+' | head -1)"
        if [[ -n "${rtt_ms}" && -n "${prof_ms}" && "${rtt_ms}" -gt $((prof_ms + 50)) ]]; then
          CAKE_RTT="${rtt_s}"
          log "实测 RTT ${rtt_ms}ms 明显高于档位 ${prof_ms}ms → CAKE_RTT=${CAKE_RTT}"
        fi
      fi
    fi
    return 0
  fi

  # RTT-only fallback
  local rtt_s rtt_ms prof
  rtt_s="$(suggest_rtt_from_ping 1.1.1.1 || true)"
  if [[ -n "${rtt_s}" ]]; then
    rtt_ms="$(printf '%s' "${rtt_s}" | grep -oE '[0-9]+' | head -1)"
    prof="$(rtt_ms_to_region "${rtt_ms}")"
    DETECTED_REGION="${prof}"
    DETECTED_GEO="RTT≈${rtt_ms}ms (no geo)"
    apply_region_profile "${prof}"
    if [[ -z "${OVERRIDE_CAKE_RTT}" ]]; then
      CAKE_RTT="${rtt_s}"
      log "RTT fallback CAKE_RTT=${CAKE_RTT} profile=${prof}"
    fi
    return 0
  fi

  warn "位置识别失败；保持 CAKE_RTT=${CAKE_RTT}。美区请: REGION=us"
  REGION_PROFILE="default"
  REGION_NOTE="无地理/无RTT，使用当前默认"
  return 0
}

parse_overrides(){
  local input="$1"
  local map_name="$2"
  local pair key value
  local -n target_map="${map_name}"

  input="${input//,/ }"
  for pair in ${input}; do
    [[ "${pair}" == *=* ]] || continue
    key="${pair%%=*}"
    value="${pair#*=}"
    [[ -n "${key}" && -n "${value}" ]] || continue
    target_map["${key}"]="${value}"
  done
}

load_overrides(){
  parse_overrides "${UP_OVERRIDES}" BANDWIDTH_UP_OVERRIDES
  parse_overrides "${DOWN_OVERRIDES}" BANDWIDTH_DOWN_OVERRIDES
}

preflight(){
  # </dev/null: 避免 wget|bash 时子进程误读脚本 stdin
  log "preflight: 检查依赖命令..."
  need_bin ip
  need_bin tc
  need_bin sysctl
  need_bin awk
  need_bin grep
  need_bin sed
  ok "依赖命令齐全 (ip/tc/sysctl/awk/grep/sed)"

  log "preflight: 加载内核模块 (bbr/cake/ifb)..."
  if have_bin modprobe; then
    modprobe tcp_bbr </dev/null 2>/dev/null || true
    for module in sch_cake ifb cls_matchall act_mirred; do
      modprobe "${module}" </dev/null 2>/dev/null || true
    done
  fi

  local available_cc
  available_cc="$(sysctl -n net.ipv4.tcp_available_congestion_control </dev/null 2>/dev/null || true)"
  log "可用拥塞控制: ${available_cc:-unknown}"
  if ! printf '%s\n' "${available_cc}" | grep -qw bbr; then
    die "BBR 不可用。当前: ${available_cc:-unknown}。请换较新内核或开启 BBR。"
  fi
  ok "BBR 可用"

  # 检测 cake：优先不破坏 lo；失败再尝试 attach lo；仍失败则硬退出
  log "preflight: 检测 sch_cake..."
  local cake_ok=0
  if tc qdisc replace dev lo root handle 1: cake </dev/null 2>/dev/null; then
    tc qdisc del dev lo root </dev/null 2>/dev/null || true
    cake_ok=1
  elif tc qdisc add dev lo root handle 1: cake </dev/null 2>/dev/null; then
    tc qdisc del dev lo root </dev/null 2>/dev/null || true
    cake_ok=1
  elif have_bin modinfo && modinfo sch_cake </dev/null >/dev/null 2>&1; then
    # 模块在但 lo 可能被占用/策略限制：再试一次 replace
    if tc qdisc replace dev lo root cake </dev/null 2>/dev/null; then
      tc qdisc del dev lo root </dev/null 2>/dev/null || true
      cake_ok=1
    fi
  fi
  if [[ "${cake_ok}" -ne 1 ]]; then
    # 最后手段：看 tc 是否认识 cake
    if tc qdisc help 2>&1 | grep -qi cake; then
      warn "tc 认识 cake，但无法在 lo 上挂载；将在真实网卡 apply 时再试"
      cake_ok=1
    fi
  fi
  if [[ "${cake_ok}" -ne 1 ]]; then
    die "sch_cake 不可用。Debian/Ubuntu 可试: apt-get install -y iproute2 && modprobe sch_cake"
  fi
  ok "sch_cake 检测通过"

  # Normalize global rates early (user may pass bare numbers)
  if [[ -n "${BANDWIDTH_UP_DEFAULT:-}" ]]; then
    BANDWIDTH_UP_DEFAULT="$(normalize_cake_rate "${BANDWIDTH_UP_DEFAULT}")"
  fi
  if [[ -n "${BANDWIDTH_DOWN_DEFAULT:-}" ]]; then
    BANDWIDTH_DOWN_DEFAULT="$(normalize_cake_rate "${BANDWIDTH_DOWN_DEFAULT}")"
  fi
  CAKE_RTT="$(printf '%s' "${CAKE_RTT:-50ms}" | tr -d '[:space:]')"
  if ! [[ "${CAKE_RTT}" =~ ^[0-9]+([.][0-9]+)?ms$ || "${CAKE_RTT}" =~ ^[0-9]+([.][0-9]+)?s$ ]]; then
    warn "CAKE_RTT='${CAKE_RTT}' 非法，改用 50ms"
    CAKE_RTT="50ms"
  fi
  ok "preflight 完成 (CAKE_RTT=${CAKE_RTT})"
}

write_sysctl(){
  local rp_filter=0
  if [[ "${PROFILE}" == "host" ]]; then
    rp_filter=1
  fi

  log "Writing ${SYSCTL_FILE}"

  cat >"${SYSCTL_FILE}" <<EOF
fs.file-max = 2097152
net.ipv4.tcp_congestion_control = bbr
net.core.default_qdisc = cake

net.ipv4.tcp_sack = 1
net.ipv4.tcp_window_scaling = 1
net.ipv4.tcp_moderate_rcvbuf = 1
net.ipv4.tcp_timestamps = 1
net.ipv4.tcp_ecn = 0
net.ipv4.tcp_rfc1337 = 1
net.ipv4.tcp_slow_start_after_idle = 0
net.ipv4.tcp_mtu_probing = 1

net.core.rmem_max = 16777216
net.core.wmem_max = 16777216
net.ipv4.tcp_rmem = 4096 87380 16777216
net.ipv4.tcp_wmem = 4096 65536 16777216
net.ipv4.udp_rmem_min = 8192
net.ipv4.udp_wmem_min = 8192

net.core.somaxconn = 8192
net.ipv4.tcp_max_syn_backlog = 8192

net.ipv4.ip_forward = ${ENABLE_FORWARDING}
net.ipv4.conf.all.forwarding = ${ENABLE_FORWARDING}
net.ipv6.conf.all.forwarding = ${ENABLE_FORWARDING}

net.ipv4.conf.all.accept_redirects = 0
net.ipv4.conf.default.accept_redirects = 0

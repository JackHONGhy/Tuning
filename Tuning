#!/usr/bin/env bash
# BBR + CAKE 自动化（多上行 + VPN 友好 + 全局 MSS 钳制）
# 要求：Linux 内核 >= 5.4，sch_cake/ifb 模块可用
set -euo pipefail

######################## 用户参数（按需调整） ########################
ENABLE_LIMITS=0                    # 1=启用限速（建议设为实测带宽的 90–95%）；0=不限速但排队
BANDWIDTH_UP_DEFAULT="300Mbit"     # 默认上行限速（每个上行可单独覆盖）
BANDWIDTH_DOWN_DEFAULT="1000Mbit"  # 默认下行限速
CAKE_RTT="100ms"                   # 典型 RTT（影响队长度）；如国内直连可 50ms
# 基础 CAKE 选项（根据需要追加 diffserv/洗标等）
BASE_CAKE_OPTS="besteffort triple-isolate ack-filter split-gso"

# 自动识别候选上行接口：
# 1) 承载默认路由的接口（IPv4/IPv6）
# 2) 名称前缀匹配 VPN：wg*, tun*, ppp*
# 排除：lo、docker/veth/virbr/ifb/bridge/kube 等常见非上行
VPN_NAME_PREFIXES="wg tun ppp"     # 空格分隔

# 仅当确实做 NAT 时启用 CAKE nat（自动探测 MASQUERADE）
AUTO_ENABLE_CAKE_NAT=1

# 为 VPN 接口自动附加 CAKE 参数（开箱即用但保守）：
AUTO_VPN_TUNING=1                  # 对 pppoe/tun/wg 增加轻量参数（见下）
# 说明：pppoe -> 附加 "pppoe"；wg/tun 默认不强加 overhead，避免误判

# IFB 与 MTU：每个上行配套 IFB（ifb-<dev>），且 MTU 跟随上行
ENABLE_INGRESS_SHAPING=1

# 全局 MSS 钳制：不仅 FORWARD（路由/NAT），也可选 OUTPUT（本机直连）
MSS_CLAMP_V4=1
MSS_CLAMP_V6=1
MSS_CLAMP_HOST_OUTPUT=1            # 1=对 OUTPUT 也钳；0=仅 FORWARD

# （可选）在 VPN 接口上禁用 GRO/GSO 以降延迟（可能牺牲吞吐，默认关）
DISABLE_GRO_GSO_ON_VPN=0

# （可选）为特定接口设置带宽（接口名=值），覆盖 DEFAULT；示例：
# declare -A BANDWIDTH_UP_OVERRIDES=( ["pppoe-wan"]="80Mbit" ["wg0"]="60Mbit" )
# declare -A BANDWIDTH_DOWN_OVERRIDES=( ["pppoe-wan"]="500Mbit" ["wg0"]="300Mbit" )
declare -A BANDWIDTH_UP_OVERRIDES=()
declare -A BANDWIDTH_DOWN_OVERRIDES=()
####################################################################

# ------- 基础校验 -------
if [[ ${EUID} -ne 0 ]]; then
  echo "[ERROR] 需要 root 权限运行。" >&2
  exit 1
fi
need_bin(){ command -v "$1" >/dev/null 2>&1 || { echo "[ERROR] 需要命令：$1"; exit 1; }; }
need_bin ip; need_bin tc; need_bin sysctl

# ------- 写入 sysctl，全局生效（BBR + 默认 CAKE） -------
echo "[*] 写入 /etc/sysctl.d/99-bbr-cake.conf"
cat >/etc/sysctl.d/99-bbr-cake.conf <<'EOF'
fs.file-max = 2097152
net.ipv4.tcp_congestion_control = bbr
net.core.default_qdisc = cake

# TCP 能力
net.ipv4.tcp_sack = 1
net.ipv4.tcp_window_scaling = 1
net.ipv4.tcp_moderate_rcvbuf = 1
net.ipv4.tcp_timestamps = 1
net.ipv4.tcp_ecn = 0
net.ipv4.tcp_rfc1337 = 1
net.ipv4.tcp_slow_start_after_idle = 0
net.ipv4.tcp_mtu_probing = 1

# 轻量缓冲
net.core.rmem_max = 16777216
net.core.wmem_max = 16777216
net.ipv4.tcp_rmem = 4096 87380 16777216
net.ipv4.tcp_wmem = 4096 65536 16777216
net.ipv4.udp_rmem_min = 8192
net.ipv4.udp_wmem_min = 8192

# 队列
net.core.somaxconn = 4096
net.ipv4.tcp_max_syn_backlog = 8192

# 转发默认关闭（脚本不强开；按需自行开启）
net.ipv4.ip_forward = 0
net.ipv4.conf.all.forwarding = 0
net.ipv6.conf.all.forwarding = 0

# 安全与兼容
net.ipv4.conf.all.accept_redirects = 0
net.ipv4.conf.default.accept_redirects = 0
net.ipv4.conf.all.send_redirects = 0
net.ipv4.conf.default.send_redirects = 0
net.ipv4.conf.all.rp_filter = 0
net.ipv4.conf.default.rp_filter = 0
EOF
sysctl --system >/dev/null

# ------- 模块（容错） -------
modprobe sch_cake 2>/dev/null || true
modprobe ifb 2>/dev/null || true

# ------- NAT 探测（是否为 CAKE 启用 nat） -------
CAKE_NAT_OPT=""
if [[ "${AUTO_ENABLE_CAKE_NAT}" -eq 1 ]]; then
  if iptables -t nat -S POSTROUTING 2>/dev/null | grep -q MASQUERADE; then
    CAKE_NAT_OPT="nat"
    echo "[*] 检测到 MASQUERADE，CAKE 将启用 nat 优化"
  fi
fi

# ------- 发现上行接口（默认路由 + VPN 命名前缀） -------
declare -A CANDIDATES=()

# 1) 默认路由的 dev（v4/v6）
while read -r dev; do [[ -n "${dev}" ]] && CANDIDATES["$dev"]=1; done < <(ip -o -4 route show default 2>/dev/null | awk '{print $5}')
while read -r dev; do [[ -n "${dev}" ]] && CANDIDATES["$dev"]=1; done < <(ip -o -6 route show default 2>/dev/null | awk '{print $5}')

# 2) VPN 前缀（即便不承载默认路由也纳入）
for p in ${VPN_NAME_PREFIXES}; do
  while read -r dev; do [[ -n "${dev}" ]] && CANDIDATES["$dev"]=1; done < <(ip -o link show | awk -F': ' '{print $2}' | grep -E "^${p}[0-9A-Za-z_-]*$" || true)
done

# 排除非上行/虚拟：lo/ifb*/veth*/docker*/virbr*/br*/kube*/tap*/macvtap*/
for dev in "${!CANDIDATES[@]}"; do
  if [[ "$dev" =~ ^(lo|ifb|veth|docker|virbr|br|kube|tap|macvtap) ]]; then
    unset "CANDIDATES[$dev]"
  fi
done

if [[ ${#CANDIDATES[@]} -eq 0 ]]; then
  echo "[ERROR] 未发现上行接口（默认路由或 VPN 前缀）。"
  exit 1
fi

echo "[*] 识别到上行接口：$(printf '%s ' "${!CANDIDATES[@]}" | xargs)"

# ------- 工具函数 -------
cleanup_qdisc(){ local d="$1"; tc qdisc del dev "$d" root 2>/dev/null || true; tc qdisc del dev "$d" ingress 2>/dev/null || true; }
ensure_ingress_hook(){ local d="$1"; tc qdisc replace dev "$d" handle ffff: ingress 2>/dev/null || true; }
dev_mtu(){ cat "/sys/class/net/$1/mtu" 2>/dev/null || echo 1500; }
is_vpn_if(){ [[ "$1" =~ ^(wg|tun|ppp) ]]; }
is_pppoe(){ [[ "$1" =~ ^(ppp|pppoe) ]]; }

# ------- 主循环：为每个上行配置 CAKE + IFB -------
for DEV in "${!CANDIDATES[@]}"; do
  echo
  echo "[*] 处理上行接口：${DEV}"

  # 设备必须是 UP
  ip link set dev "${DEV}" up || true

  # 清理原有 qdisc
  cleanup_qdisc "${DEV}"

  # 组装 CAKE 参数
  CAKE_OPTS="${BASE_CAKE_OPTS}"
  [[ -n "${CAKE_NAT_OPT}" ]] && CAKE_OPTS="${CAKE_OPTS} ${CAKE_NAT_OPT}"

  if [[ "${AUTO_VPN_TUNING}" -eq 1 ]]; then
    if is_pppoe "${DEV}"; then
      CAKE_OPTS="${CAKE_OPTS} pppoe"           # 自动识别 PPPoE
    fi
    # 对 wg/tun 不强加 overhead（不同封装差异大；避免误判）
  fi

  # 带宽（可被 overrides 覆盖）
  UP_RATE="${BANDWIDTH_UP_OVERRIDES[$DEV]:-${BANDWIDTH_UP_DEFAULT}}"
  DOWN_RATE="${BANDWIDTH_DOWN_OVERRIDES[$DEV]:-${BANDWIDTH_DOWN_DEFAULT}}"

  # 配置 egress CAKE
  if [[ "${ENABLE_LIMITS}" -eq 1 ]]; then
    echo "  - egress CAKE：限速 ${UP_RATE}，rtt ${CAKE_RTT}，opts [${CAKE_OPTS}]"
    tc qdisc replace dev "${DEV}" root cake bandwidth "${UP_RATE}" rtt "${CAKE_RTT}" ${CAKE_OPTS}
  else
    echo "  - egress CAKE：不限速，rtt ${CAKE_RTT}，opts [${CAKE_OPTS}]"
    tc qdisc replace dev "${DEV}" root cake rtt "${CAKE_RTT}" ${CAKE_OPTS}
  fi

  # 配置 ingress（IFB）
  if [[ "${ENABLE_INGRESS_SHAPING}" -eq 1 ]]; then
    IFB="ifb-${DEV}"
    # 复用或创建 IFB
    if ! ip link show "${IFB}" >/dev/null 2>&1; then
      ip link add "${IFB}" type ifb 2>/dev/null || { echo "  ! 创建 IFB ${IFB} 失败，跳过该接口的 ingress 整形"; continue; }
    fi
    ip link set dev "${IFB}" up
    ip link set dev "${IFB}" mtu "$(dev_mtu "${DEV}")" || true

    ensure_ingress_hook "${DEV}"
    # 更稳健的 matchall（pref+protocol）
    tc filter replace dev "${DEV}" ingress pref 1 protocol all matchall \
      action mirred egress redirect dev "${IFB}"

    # IFB 上 CAKE 使用 ingress 模式
    cleanup_qdisc "${IFB}"
    if [[ "${ENABLE_LIMITS}" -eq 1 ]]; then
      echo "  - ingress CAKE@${IFB}：限速 ${DOWN_RATE}，rtt ${CAKE_RTT}，opts [${CAKE_OPTS}] + ingress"
      tc qdisc replace dev "${IFB}" root cake bandwidth "${DOWN_RATE}" rtt "${CAKE_RTT}" ${CAKE_OPTS} ingress
    else
      echo "  - ingress CAKE@${IFB}：不限速，rtt ${CAKE_RTT}，opts [${CAKE_OPTS}] + ingress"
      tc qdisc replace dev "${IFB}" root cake rtt "${CAKE_RTT}" ${CAKE_OPTS} ingress
    fi
  fi

  # 可选：VPN 接口禁用 GRO/GSO（更稳更低延迟，但可能掉速）
  if [[ "${DISABLE_GRO_GSO_ON_VPN}" -eq 1 ]] && is_vpn_if "${DEV}"; then
    ethtool -K "${DEV}" gro off gso off tso off 2>/dev/null || true
    echo "  - 已对 ${DEV} 关闭 GRO/GSO/TSO（若需恢复请手动开启）"
  fi
done

# ------- TCPMSS 钳制（FORWARD + 可选 OUTPUT） -------
add_mss_if_absent(){
  local bin="$1" tbl="$2"; shift 2
  command -v "${bin}" >/dev/null 2>&1 || return 0
  ${bin} -t "${tbl}" -C "$@" 2>/dev/null || ${bin} -t "${tbl}" -A "$@"
}
if [[ "${MSS_CLAMP_V4}" -eq 1 ]]; then
  echo "[*] IPv4 MSS 钳制：FORWARD${MSS_CLAMP_HOST_OUTPUT:+ + OUTPUT}"
  add_mss_if_absent iptables mangle FORWARD -p tcp --tcp-flags SYN,RST SYN -j TCPMSS --clamp-mss-to-pmtu
  if [[ "${MSS_CLAMP_HOST_OUTPUT}" -eq 1 ]]; then
    add_mss_if_absent iptables mangle OUTPUT  -p tcp --tcp-flags SYN,RST SYN -j TCPMSS --clamp-mss-to-pmtu
  fi
fi
if [[ "${MSS_CLAMP_V6}" -eq 1 ]]; then
  echo "[*] IPv6 MSS 钳制：FORWARD${MSS_CLAMP_HOST_OUTPUT:+ + OUTPUT}"
  add_mss_if_absent ip6tables mangle FORWARD -p tcp --tcp-flags SYN,RST SYN -j TCPMSS --clamp-mss-to-pmtu
  if [[ "${MSS_CLAMP_HOST_OUTPUT}" -eq 1 ]]; then
    add_mss_if_absent ip6tables mangle OUTPUT  -p tcp --tcp-flags SYN,RST SYN -j TCPMSS --clamp-mss-to-pmtu
  fi
fi

# ------- 展示状态 -------
echo
echo "====== 队列状态（每个上行） ======"
for DEV in "${!CANDIDATES[@]}"; do
  echo "--- ${DEV} ---"
  tc -s qdisc show dev "${DEV}" | sed -n '1,160p' || true
  IFB="ifb-${DEV}"
  if ip link show "${IFB}" >/dev/null 2>&1; then
    echo "--- ${IFB} ---"
    tc -s qdisc show dev "${IFB}" | sed -n '1,160p' || true
  fi
done

echo
if [[ "${ENABLE_LIMITS}" -eq 1 ]]; then
  echo "[OK] 已应用 BBR + CAKE（多上行，限速启用）。"
else
  echo "[OK] 已应用 BBR + CAKE（多上行，不限速）。"
fi

EOF

  cat >"${RETUNE_TIMER_FILE}" <<EOF
[Unit]
Description=Daily BBR+CAKE retune at Beijing time ${hh}:${mm}

[Timer]
# systemd Timezone= requires reasonably new systemd
OnCalendar=*-*-* ${hh}:${mm}:00
Timezone=Asia/Shanghai
Persistent=true
Unit=${RETUNE_SERVICE_NAME}

[Install]
WantedBy=timers.target
EOF
}

install_cmd(){
  require_root
  load_overrides
  preflight
  resolve_bandwidth
  resolve_cake_rtt
  maybe_adjust_ingress_for_cpu
  install_self
  write_env_file
  write_service_file
  write_retune_units

  systemctl daemon-reload
  systemctl enable "${SERVICE_NAME}" >/dev/null
  systemctl restart "${SERVICE_NAME}"

  if [[ "${DAILY_RETEST}" == "1" ]]; then
    systemctl enable --now "${RETUNE_TIMER_NAME}" >/dev/null 2>&1 || true
    systemctl start "${RETUNE_TIMER_NAME}" 2>/dev/null || true
  fi

  ok "Installed and enabled ${SERVICE_NAME}."
  echo "[CONFIG] ${ENV_FILE}"
  echo "[SCRIPT] ${INSTALL_PATH}"
  echo "[SERVICE] ${SERVICE_FILE}"
  echo "[TIMER] ${RETUNE_TIMER_FILE} DAILY_RETEST=${DAILY_RETEST} Beijing ${RETEST_HOUR}:$(printf '%02d' "${RETEST_MINUTE}")"
  echo "[BW] source=${BANDWIDTH_SOURCE} UP=${BANDWIDTH_UP_DEFAULT:-none} DOWN=${BANDWIDTH_DOWN_DEFAULT:-none} limits=${ENABLE_LIMITS}"
  systemctl list-timers "${RETUNE_TIMER_NAME}" --no-pager 2>/dev/null || true
}

cleanup_runtime(){
  load_overrides
  preflight
  discover_candidates

  local dev ifb
  for dev in "${!CANDIDATES[@]}"; do
    log "Cleaning qdisc on ${dev}"
    cleanup_qdisc "${dev}"

    ifb="$(ifb_name "${dev}")"
    if ip link show "${ifb}" >/dev/null 2>&1; then
      ip link delete "${ifb}" 2>/dev/null || true
    fi
  done

  # Orphan IFB from previous interface renames (our naming prefix only)
  if have_bin ip; then
    local line name
    while read -r line; do
      name="$(printf '%s' "${line}" | awk -F': ' '{print $2}' | awk -F'@' '{print $1}')"
      [[ "${name}" == ifb-* ]] || continue
      log "Removing orphan IFB ${name}"
      ip link delete "${name}" 2>/dev/null || true
    done < <(ip -o link show 2>/dev/null | grep -E 'ifb-' || true)
  fi

  cleanup_mss
  ok "Cleaned runtime qdisc/IFB/MSS state."
}

# cleanup = 运行时网络规则 + 临时文件；不碰安装配置/服务/限速参数
cleanup_cmd(){
  require_root
  echo "====== cleanup (保留配置与 systemd) ======"
  echo "将清理: tc/qdisc, IFB, MSS clamp, /tmp/bbr-cake.* 临时文件"
  echo "不清理: ${ENV_FILE}, 服务/定时器, ${SYSCTL_FILE}, 测速缓存, 进度, 安装脚本"
  cleanup_runtime || true
  cleanup_temps
  rotate_retune_log
  # stale bench fail snippet older than 7 days
  if [[ -f "${BENCH_FAIL_SNIPPET}" ]] && have_bin find; then
    find "${CACHE_DIR}" -maxdepth 1 -name 'bench-last-fail.txt' -mtime +7 -delete 2>/dev/null || true
  fi
  ok "cleanup 完成。若需恢复整形: $0 apply  或  $0 retune"
  echo "完全卸载请用: $0 uninstall"
}

uninstall_cmd(){
  require_root

  if have_bin systemctl; then
    systemctl stop "${RETUNE_TIMER_NAME}" 2>/dev/null || true
    systemctl disable "${RETUNE_TIMER_NAME}" >/dev/null 2>&1 || true
    systemctl stop "${RETUNE_SERVICE_NAME}" 2>/dev/null || true
    systemctl stop "${SERVICE_NAME}" 2>/dev/null || true
    systemctl disable "${SERVICE_NAME}" >/dev/null 2>&1 || true
  else
    cleanup_runtime || true
  fi

  cleanup_temps quiet 2>/dev/null || true
  cleanup_runtime 2>/dev/null || true

  rm -f "${SERVICE_FILE}" "${RETUNE_SERVICE_FILE}" "${RETUNE_TIMER_FILE}"
  rm -f "${ENV_FILE}" "${SYSCTL_FILE}" "${INSTALL_PATH}"
  rm -f "${DETECT_CACHE_FILE}" "${PROGRESS_FILE}" "${BENCH_FAIL_SNIPPET}"
  rm -rf "${RETUNE_LOG_DIR}" 2>/dev/null || true
  rm -rf "${CACHE_DIR}" 2>/dev/null || true
  # any leftover session dirs
  rm -rf /tmp/bbr-cake.* 2>/dev/null || true

  if have_bin systemctl; then
    systemctl daemon-reload
  fi

  sysctl --system >/dev/null 2>&1 || true
  ok "Uninstalled completely (rules + config + timer + logs + temps)."
}

status_cmd(){
  echo "====== version ======"
  echo "v${VERSION}  (transit production + region profiles)"
  echo "Beijing now: $(TZ=Asia/Shanghai date '+%Y-%m-%d %H:%M:%S %Z' 2>/dev/null || date)"

  echo
  echo "====== region / geo ======"
  echo "REGION=${REGION}  GEO_DETECT=${GEO_DETECT}"
  echo "profile=${REGION_PROFILE:-?}  detected_region=${DETECTED_REGION:-?}"
  echo "country=${DETECTED_COUNTRY:-?}  geo=${DETECTED_GEO:-?}"
  echo "CAKE_RTT=${CAKE_RTT}  safety=${BANDWIDTH_SAFETY_FACTOR}"
  echo "note=${REGION_NOTE:-}"
  if [[ -f "${ENV_FILE}" ]]; then
    grep -E '^(REGION|GEO_DETECT|DETECTED_|REGION_PROFILE|CAKE_RTT|BANDWIDTH_SAFETY)=' "${ENV_FILE}" 2>/dev/null || true
  fi

  echo
  echo "====== progress (可视化当前步骤) ======"
  if [[ -f "${PROGRESS_FILE}" ]]; then
    cat "${PROGRESS_FILE}"
  else
    echo "No ${PROGRESS_FILE} (run auto/retune first)"
  fi

  echo
  echo "====== sysctl ======"
  sysctl net.ipv4.tcp_congestion_control 2>/dev/null || true
  sysctl net.core.default_qdisc 2>/dev/null || true
  sysctl net.ipv4.ip_forward 2>/dev/null || true
  sysctl net.ipv6.conf.all.forwarding 2>/dev/null || true
  sysctl net.ipv4.conf.all.rp_filter 2>/dev/null || true

  echo
  echo "====== bandwidth config ======"
  if [[ -f "${ENV_FILE}" ]]; then
    grep -E '^(ENABLE_LIMITS|UP_RATE|DOWN_RATE|BANDWIDTH_SOURCE|CAKE_RTT|PROFILE|BANDWIDTH_SAFETY_FACTOR|AGGREGATE_MODE|DETECT_ROUNDS|MAX_|DAILY_|RETEST_|REGION|CPU_)=' "${ENV_FILE}" 2>/dev/null || true
  else
    echo "No ${ENV_FILE}"
  fi
  if [[ -f "${DETECT_CACHE_FILE}" ]]; then
    echo "--- detect cache ---"
    cat "${DETECT_CACHE_FILE}"
  else
    echo "No detect cache"
  fi

  echo
  echo "====== service / timer ======"
  if have_bin systemctl; then
    systemctl is-enabled "${SERVICE_NAME}" 2>/dev/null || true
    systemctl is-active "${SERVICE_NAME}" 2>/dev/null || true
    echo "--- retune timer ---"
    systemctl is-enabled "${RETUNE_TIMER_NAME}" 2>/dev/null || true
    systemctl list-timers "${RETUNE_TIMER_NAME}" --no-pager 2>/dev/null || true
  else
    echo "systemctl not available"
  fi

  echo
  echo "====== CPU snapshot ======"
  echo "cores=$(cpu_nproc) load_pct≈$(cpu_load_pct)% soft_max_mbit=$(cpu_soft_max_mbit)"

  load_overrides
  if have_bin ip && have_bin tc; then
    if discover_candidates 2>/dev/null; then
      show_qdisc_status
    fi
  fi

  echo
  echo "====== retune log (tail) ======"
  if [[ -f "${RETUNE_LOG_FILE}" ]]; then
    tail -n 30 "${RETUNE_LOG_FILE}" 2>/dev/null || true
  else
    echo "No ${RETUNE_LOG_FILE} yet"
  fi

  echo
  echo "====== MSS rules ======"
  if have_bin iptables; then
    iptables -t mangle -S 2>/dev/null | grep TCPMSS || true
  fi
  if have_bin ip6tables; then
    ip6tables -t mangle -S 2>/dev/null | grep TCPMSS || true
  fi
}

# Non-destructive health check (read-only where possible)
selfcheck_cmd(){
  echo "====== selfcheck v${VERSION} ======"
  local fail=0
  echo "kernel: $(uname -r 2>/dev/null || echo unknown)"
  echo "uid: ${EUID}"
  for b in ip tc sysctl awk grep sed; do
    if have_bin "${b}"; then ok "bin ${b}"; else warn "missing ${b}"; fail=1; fi
  done
  if have_bin modprobe; then
    modprobe tcp_bbr </dev/null 2>/dev/null || true
    modprobe sch_cake </dev/null 2>/dev/null || true
  fi
  local cc
  cc="$(sysctl -n net.ipv4.tcp_available_congestion_control </dev/null 2>/dev/null || true)"
  if printf '%s' "${cc}" | grep -qw bbr; then ok "BBR available (${cc})"; else warn "BBR missing"; fail=1; fi
  if tc qdisc replace dev lo root cake </dev/null 2>/dev/null; then
    ok "sch_cake works on lo"
    tc qdisc del dev lo root </dev/null 2>/dev/null || true
  else
    warn "sch_cake not working"
    fail=1
  fi
  echo "REGION=${REGION} GEO_DETECT=${GEO_DETECT} DETECT_ROUNDS=${DETECT_ROUNDS}"
  echo "DETECT_METHODS=${DETECT_METHODS} AUTO_BENCH_FALLBACK=${AUTO_BENCH_FALLBACK}"
  echo "safety=${BANDWIDTH_SAFETY_FACTOR} aggregate=${AGGREGATE_MODE}"
  if [[ -f "${ENV_FILE}" ]]; then ok "env ${ENV_FILE}"; else log "no env yet (not installed)"; fi
  if have_bin systemctl; then
    if systemctl cat "${SERVICE_NAME}" &>/dev/null; then
      local en
      en="$(systemctl is-enabled "${SERVICE_NAME}" 2>/dev/null || echo disabled)"
      ok "service unit present (enabled=${en})"
    else
      log "service not installed yet (run full install to create)"
    fi
    if systemctl cat "${RETUNE_TIMER_NAME}" &>/dev/null; then
      local ten
      ten="$(systemctl is-enabled "${RETUNE_TIMER_NAME}" 2>/dev/null || echo disabled)"
      ok "retune timer present (enabled=${ten})"
    else
      log "retune timer not installed yet"
    fi
  fi
  local t
  t="$(normalize_cake_rate 100)"
  if [[ "${t}" == "100Mbit" ]]; then ok "normalize 100→100Mbit"; else warn "normalize failed: ${t}"; fail=1; fi
  if [[ "${fail}" -eq 0 ]]; then
    ok "selfcheck PASSED — 可执行: sudo bash $0"
    return 0
  fi
  warn "selfcheck found issues (exit 1)"
  return 1
}

main(){
  # Default: full auto (detect → fill → apply → install)
  local cmd="${1:-auto}"

  case "${cmd}" in
    auto|"")
      auto_cmd
      ;;
    detect)
      detect_cmd
      ;;
    retune|daily-retune|redetect)
      retune_cmd
      ;;
    apply)
      apply_cmd
      ;;
    install)
      install_cmd
      ;;
    status)
      status_cmd
      ;;
    selfcheck|doctor|check)
      selfcheck_cmd
      ;;
    cleanup|clean)
      cleanup_cmd
      ;;
    cleanup-temps|clean-temps)
      require_root
      cleanup_temps
      rotate_retune_log
      ok "仅清理临时文件与日志轮转（未动 qdisc）"
      ;;
    uninstall)
      uninstall_cmd
      ;;
    -h|--help|help)
      usage
      ;;
    -v|--version|version)
      echo "v${VERSION}"
      ;;
    *)
      usage
      die "Unknown command: ${cmd}"
      ;;
  esac
}

main "$@"

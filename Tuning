# ---------- progress / logging (line-buffered, visible under pipe|bash) ----------
log(){ printf '[*] %s\n' "$*"; }
ok(){ printf '[OK] %s\n' "$*"; }
warn(){ printf '[WARN] %s\n' "$*" >&2; }
die(){ printf '[ERROR] %s\n' "$*" >&2; exit 1; }

# Defined early: cleanup_temps / traps may run before later helpers
need_bin(){ command -v "$1" >/dev/null 2>&1 || die "Missing command: $1"; }
have_bin(){ command -v "$1" >/dev/null 2>&1; }

ts_now(){ date '+%H:%M:%S' 2>/dev/null || echo '--:--:--'; }

# ---------- temp file lifecycle (clean after tests; keep config) ----------
# KEEP: ENV_FILE, SERVICE/TIMER, INSTALL_PATH, SYSCTL, DETECT_CACHE, PROGRESS, RETUNE_LOG (rotated)
# CLEAN: /tmp/bbr-cake.* session dirs, mktemp downloads, bench workdir, stale orphans, oversized logs

register_temp(){
  local p="$1"
  [[ -n "${p}" ]] || return 0
  TRACKED_TEMPS+=("${p}")
}

ensure_session_temp_root(){
  if [[ -n "${SESSION_TEMP_ROOT}" && -d "${SESSION_TEMP_ROOT}" ]]; then
    return 0
  fi
  SESSION_TEMP_ROOT="$(mktemp -d /tmp/bbr-cake.XXXXXX 2>/dev/null || mktemp -d)"
  register_temp "${SESSION_TEMP_ROOT}"
  CLEANUP_TEMPS_DONE=0
}

# Create file under session root (auto-tracked)
make_temp_file(){
  ensure_session_temp_root
  local f
  f="$(mktemp "${SESSION_TEMP_ROOT}/f.XXXXXX")"
  register_temp "${f}"
  printf '%s' "${f}"
}

make_temp_dir(){
  ensure_session_temp_root
  local d
  d="$(mktemp -d "${SESSION_TEMP_ROOT}/d.XXXXXX")"
  register_temp "${d}"
  printf '%s' "${d}"
}

# Remove all session temps + stale bbr-cake.* under /tmp older than 2h
cleanup_temps(){
  local quiet="${1:-}"  # quiet|verbose
  local p
  # set -u safe empty array
  if [[ ${#TRACKED_TEMPS[@]} -gt 0 ]]; then
    for p in "${TRACKED_TEMPS[@]}"; do
      [[ -n "${p}" ]] || continue
      rm -rf "${p}" 2>/dev/null || true
    done
  fi
  TRACKED_TEMPS=()
  if [[ -n "${SESSION_TEMP_ROOT}" ]]; then
    rm -rf "${SESSION_TEMP_ROOT}" 2>/dev/null || true
    SESSION_TEMP_ROOT=""
  fi
  # Orphans from killed runs (only our prefix)
  if command -v find >/dev/null 2>&1; then
    find /tmp -maxdepth 1 -type d -name 'bbr-cake.*' -mmin +120 -exec rm -rf {} + 2>/dev/null || true
    find /tmp -maxdepth 1 -type f -name 'bbr-cake.*' -mmin +120 -exec rm -f {} + 2>/dev/null || true
  else
    # nullglob-safe: only expand if matches
    local g
    shopt -s nullglob 2>/dev/null || true
    for g in /tmp/bbr-cake.*; do
      rm -rf "${g}" 2>/dev/null || true
    done
    shopt -u nullglob 2>/dev/null || true
  fi
  CLEANUP_TEMPS_DONE=1
  [[ "${quiet}" == "quiet" ]] || log "已清理测速临时文件 (/tmp/bbr-cake.* 会话目录)"
}

# Truncate retune log if too large (keep last ~1500 lines)
rotate_retune_log(){
  [[ -f "${RETUNE_LOG_FILE}" ]] || return 0
  local sz
  sz="$(wc -c <"${RETUNE_LOG_FILE}" 2>/dev/null | tr -d ' ' || echo 0)"
  [[ "${sz}" =~ ^[0-9]+$ ]] || return 0
  if [[ "${sz}" -gt "${RETUNE_LOG_MAX_BYTES}" ]]; then
    local tmp
    tmp="$(mktemp 2>/dev/null || echo /tmp/bbr-cake-logtrim.$$)"
    tail -n 1500 "${RETUNE_LOG_FILE}" >"${tmp}" 2>/dev/null || true
    mv -f "${tmp}" "${RETUNE_LOG_FILE}" 2>/dev/null || cat "${tmp}" >"${RETUNE_LOG_FILE}"
    rm -f "${tmp}" 2>/dev/null || true
    log "retune 日志已轮转 (原 ${sz} bytes → 保留尾部)"
  fi
}

# Post-detect housekeeping: temps + log rotate (never touch CAKE/config)
post_detect_housekeeping(){
  cleanup_temps quiet
  rotate_retune_log
  log "测速后清理完成（已删临时文件；保留配置/限速/服务/缓存/进度）"
}

# Best-effort trap: Ctrl+C during detect still drops temps
_on_signal_cleanup_temps(){
  cleanup_temps quiet 2>/dev/null || true
}
# Only register once
if [[ -z "${_BBR_CAKE_TRAP_SET:-}" ]]; then
  _BBR_CAKE_TRAP_SET=1
  trap '_on_signal_cleanup_temps' INT TERM
fi

# Big stage banner: phase current/total title
phase(){
  local cur="$1" total="$2" title="$3"
  echo
  echo "══════════════════════════════════════════════"
  printf ' ▶ 阶段 %s/%s  |  %s  |  %s\n' "${cur}" "${total}" "$(ts_now)" "${title}"
  echo "══════════════════════════════════════════════"
}

# Sub-step within a phase
step(){
  printf '\n>>> [%s] %s\n' "$(ts_now)" "$*"
}

# Persist progress for status / parallel SSH watchers
# usage: progress_set STEP TOTAL TITLE [DETAIL]
progress_set(){
  local cur="$1" total="$2" title="$3" detail="${4:-}"
  mkdir -p "$(dirname "${PROGRESS_FILE}")" 2>/dev/null || true
  {
    echo "timestamp=$(date -Is 2>/dev/null || date)"
    echo "beijing=$(TZ=Asia/Shanghai date '+%Y-%m-%d %H:%M:%S %Z' 2>/dev/null || date)"
    echo "step=${cur}"
    echo "total=${total}"
    echo "title=${title}"
    echo "detail=${detail}"
    echo "version=${VERSION}"
    echo "pid=$$"
  } >"${PROGRESS_FILE}" 2>/dev/null || true
  phase "${cur}" "${total}" "${title}"
  if [[ -n "${detail:-}" ]]; then
    log "${detail}"
  fi
}

progress_done(){
  progress_set "${1:-1}" "${1:-1}" "完成" "${2:-ok}"
}

# Run command with live console output + capture file (for parsing)
# Usage: run_live /path/out.txt cmd [args...]
run_live(){
  local out="$1"
  shift
  local rc=0
  if [[ "${LIVE_OUTPUT}" != "1" ]]; then
    "$@" >"${out}" 2>&1 || rc=$?
    return "${rc}"
  fi
  # Prefer line-buffered so progress appears immediately (esp. under curl|bash)
  # Temporarily disable -e: pipelines + pipefail would abort the whole script
  set +e
  if command -v stdbuf >/dev/null 2>&1; then
    stdbuf -oL -eL "$@" 2>&1 | tee "${out}"
  else
    "$@" 2>&1 | tee "${out}"
  fi
  rc="${PIPESTATUS[0]:-0}"
  set -e
  return "${rc}"
}

require_root(){
  [[ ${EUID} -eq 0 ]] || die "Please run as root."
}

is_tty(){
  [[ -t 0 && -t 1 ]]
}

# Normalize user/detect rates for tc cake (accept 100, 100M, 100Mbit)
normalize_cake_rate(){
  local r="${1:-}"
  r="$(printf '%s' "${r}" | tr -d '[:space:]')"
  [[ -n "${r}" ]] || { printf ''; return 0; }
  if [[ "${r}" =~ ^[0-9]+(\.[0-9]+)?$ ]]; then
    printf '%sMbit' "$(awk -v v="${r}" 'BEGIN{printf "%d", int(v+0.5)}')"
    return 0
  fi
  if [[ "${r}" =~ ^([0-9]+(\.[0-9]+)?)[Mm]$ ]]; then
    printf '%sMbit' "$(awk -v v="${BASH_REMATCH[1]}" 'BEGIN{printf "%d", int(v+0.5)}')"
    return 0
  fi
  if [[ "${r}" =~ ^([0-9]+(\.[0-9]+)?)[Gg]$ ]]; then
    printf '%sMbit' "$(awk -v v="${BASH_REMATCH[1]}" 'BEGIN{printf "%d", int(v*1000+0.5)}')"
    return 0
  fi
  printf '%s' "${r}"
}

is_valid_cake_rate(){
  local r m
  r="$(normalize_cake_rate "${1:-}")"
  [[ -n "${r}" ]] || return 1
  m="$(rate_to_mbit "${r}")"
  [[ -n "${m}" && "${m}" =~ ^[0-9]+$ && "${m}" -gt 0 ]]
}


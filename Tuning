detect_cake_nat(){
  CAKE_NAT_OPT=""
  [[ "${AUTO_ENABLE_CAKE_NAT}" -eq 1 ]] || return 0

  local has_nat=0

  if have_bin iptables; then
    if iptables -t nat -S POSTROUTING 2>/dev/null | grep -Eiq 'MASQUERADE|SNAT'; then
      has_nat=1
    fi
  fi

  if have_bin nft; then
    if nft list ruleset 2>/dev/null | grep -Eiq 'masquerade|snat'; then
      has_nat=1
    fi
  fi

  if [[ "${has_nat}" -eq 1 ]]; then
    CAKE_NAT_OPT="nat"
    log "NAT detected, enabling CAKE nat mode"
  fi
}

add_candidate(){
  local dev="${1%%@*}"
  [[ -n "${dev}" ]] || return 0
  [[ -d "/sys/class/net/${dev}" ]] || return 0
  CANDIDATES["${dev}"]=1
}

discover_candidates(){
  CANDIDATES=()

  while read -r dev; do
    add_candidate "${dev}"
  done < <(ip -o -4 route show default 2>/dev/null | awk '{for (i=1; i<=NF; i++) if ($i=="dev") print $(i+1)}')

  while read -r dev; do
    add_candidate "${dev}"
  done < <(ip -o -6 route show default 2>/dev/null | awk '{for (i=1; i<=NF; i++) if ($i=="dev") print $(i+1)}')

  if [[ "${INCLUDE_VPN_PREFIX_INTERFACES}" -eq 1 ]]; then
    local p
    for p in ${VPN_NAME_PREFIXES}; do
      while read -r dev; do
        add_candidate "${dev}"
      done < <(ip -o link show | awk -F': ' '{print $2}' | awk -F'@' '{print $1}' | grep -E "^${p}[0-9A-Za-z_.-]*$" || true)
    done
  fi

  local dev
  for dev in ${EXTRA_WAN_INTERFACES}; do
    add_candidate "${dev}"
  done

  for dev in "${!CANDIDATES[@]}"; do
    if [[ "${dev}" =~ ^(lo|ifb|veth|docker|virbr|br-|br|kube|tap|macvtap) ]]; then
      unset "CANDIDATES[${dev}]"
    fi
  done

  [[ ${#CANDIDATES[@]} -gt 0 ]] || die "No egress interface found. Check ip route or set EXTRA_WAN_INTERFACES."
}

cleanup_qdisc(){
  local dev="$1"
  tc qdisc del dev "${dev}" root 2>/dev/null || true
  tc qdisc del dev "${dev}" ingress 2>/dev/null || true
}

ensure_ingress_hook(){
  local dev="$1"
  tc qdisc replace dev "${dev}" handle ffff: ingress 2>/dev/null || true
}

dev_mtu(){
  cat "/sys/class/net/$1/mtu" 2>/dev/null || echo 1500
}

is_vpn_if(){
  [[ "$1" =~ ^(wg|tun|ppp) ]]
}

is_pppoe(){
  [[ "$1" =~ ^(ppp|pppoe) ]]
}

ifb_name(){
  local dev="$1"
  local clean="${dev//[^A-Za-z0-9_.-]/-}"
  clean="${clean:0:11}"
  printf 'ifb-%s' "${clean}"
}

append_cake_opt(){
  local current="$1"
  local opt="$2"

  if [[ " ${current} " == *" ${opt} "* ]]; then
    printf '%s' "${current}"
  else
    printf '%s %s' "${current}" "${opt}"
  fi
}

apply_qdisc(){
  log "Egress interfaces: $(printf '%s ' "${!CANDIDATES[@]}" | xargs 2>/dev/null || printf '%s ' "${!CANDIDATES[@]}")"

  local limits_on=0
  if [[ "${ENABLE_LIMITS}" == "1" ]]; then
    limits_on=1
  fi

  local dev ifb cake_opts up_rate down_rate
  for dev in "${!CANDIDATES[@]}"; do
    echo
    log "Configuring egress interface: ${dev}"

    ip link set dev "${dev}" up || true
    cleanup_qdisc "${dev}"

    cake_opts="${BASE_CAKE_OPTS}"
    if [[ -n "${CAKE_NAT_OPT:-}" ]]; then
      cake_opts="$(append_cake_opt "${cake_opts}" "${CAKE_NAT_OPT}")"
    fi
    if is_pppoe "${dev}"; then
      cake_opts="$(append_cake_opt "${cake_opts}" "pppoe")"
    fi

    up_rate="$(normalize_cake_rate "${BANDWIDTH_UP_OVERRIDES[$dev]:-${BANDWIDTH_UP_DEFAULT}}")"
    down_rate="$(normalize_cake_rate "${BANDWIDTH_DOWN_OVERRIDES[$dev]:-${BANDWIDTH_DOWN_DEFAULT}}")"

    if [[ "${limits_on}" -eq 1 && -n "${up_rate}" ]] && is_valid_cake_rate "${up_rate}"; then
      echo "  - egress CAKE: ${up_rate}, rtt ${CAKE_RTT}, opts [${cake_opts}]"
      # shellcheck disable=SC2086
      if ! tc qdisc replace dev "${dev}" root cake bandwidth "${up_rate}" rtt "${CAKE_RTT}" ${cake_opts}; then
        warn "tc egress cake failed on ${dev}; trying unlimited cake"
        # shellcheck disable=SC2086
        tc qdisc replace dev "${dev}" root cake rtt "${CAKE_RTT}" ${cake_opts} || warn "tc egress failed on ${dev}"
      fi
    else
      [[ "${limits_on}" -eq 1 && -n "${up_rate}" ]] && warn "invalid UP_RATE '${up_rate}' → unlimited egress"
      echo "  - egress CAKE: unlimited, rtt ${CAKE_RTT}, opts [${cake_opts}]"
      # shellcheck disable=SC2086
      tc qdisc replace dev "${dev}" root cake rtt "${CAKE_RTT}" ${cake_opts} || warn "tc egress failed on ${dev}"
    fi

    if [[ "${ENABLE_INGRESS_SHAPING}" -eq 1 ]]; then
      ifb="$(ifb_name "${dev}")"

      if ! ip link show "${ifb}" >/dev/null 2>&1; then
        ip link add "${ifb}" type ifb 2>/dev/null || {
          warn "Failed to create IFB ${ifb}; skipping ingress shaping for ${dev}"
          continue
        }
      fi

      ip link set dev "${ifb}" up
      ip link set dev "${ifb}" mtu "$(dev_mtu "${dev}")" || true

      ensure_ingress_hook "${dev}"
      tc filter replace dev "${dev}" ingress pref 1 protocol all matchall \
        action mirred egress redirect dev "${ifb}"

      cleanup_qdisc "${ifb}"

      if [[ "${limits_on}" -eq 1 && -n "${down_rate}" ]] && is_valid_cake_rate "${down_rate}"; then
        echo "  - ingress CAKE@${ifb}: ${down_rate}, rtt ${CAKE_RTT}, opts [${cake_opts}] + ingress"
        # shellcheck disable=SC2086
        if ! tc qdisc replace dev "${ifb}" root cake bandwidth "${down_rate}" rtt "${CAKE_RTT}" ${cake_opts} ingress; then
          warn "tc ingress cake failed on ${ifb}; trying unlimited"
          # shellcheck disable=SC2086
          tc qdisc replace dev "${ifb}" root cake rtt "${CAKE_RTT}" ${cake_opts} ingress || warn "tc ingress failed"
        fi
      else
        [[ "${limits_on}" -eq 1 && -n "${down_rate}" ]] && warn "invalid DOWN_RATE '${down_rate}' → unlimited ingress"
        echo "  - ingress CAKE@${ifb}: unlimited, rtt ${CAKE_RTT}, opts [${cake_opts}] + ingress"
        # shellcheck disable=SC2086
        tc qdisc replace dev "${ifb}" root cake rtt "${CAKE_RTT}" ${cake_opts} ingress || warn "tc ingress failed"
      fi
    fi

    if [[ "${DISABLE_GRO_GSO_ON_VPN}" -eq 1 ]] && is_vpn_if "${dev}"; then
      if have_bin ethtool; then
        ethtool -K "${dev}" gro off gso off tso off 2>/dev/null || true
        echo "  - Disabled GRO/GSO/TSO on ${dev}"
      fi
    fi
  done
}

add_mss_if_absent(){
  local bin="$1"
  local table="$2"
  shift 2

  have_bin "${bin}" || return 0
  "${bin}" -t "${table}" -C "$@" 2>/dev/null || "${bin}" -t "${table}" -A "$@"
}

delete_mss_if_present(){
  local bin="$1"
  local table="$2"
  shift 2

  have_bin "${bin}" || return 0
  while "${bin}" -t "${table}" -C "$@" 2>/dev/null; do
    "${bin}" -t "${table}" -D "$@" 2>/dev/null || break
  done
}

apply_mss(){
  local scope
  if [[ "${MSS_CLAMP_HOST_OUTPUT}" -eq 1 ]]; then
    scope="FORWARD + OUTPUT"
  else
    scope="FORWARD"
  fi

  if [[ "${MSS_CLAMP_V4}" -eq 1 ]]; then
    log "IPv4 MSS clamp: ${scope}"
    add_mss_if_absent iptables mangle FORWARD -p tcp --tcp-flags SYN,RST SYN -j TCPMSS --clamp-mss-to-pmtu
    if [[ "${MSS_CLAMP_HOST_OUTPUT}" -eq 1 ]]; then
      add_mss_if_absent iptables mangle OUTPUT -p tcp --tcp-flags SYN,RST SYN -j TCPMSS --clamp-mss-to-pmtu
    fi
  fi

  if [[ "${MSS_CLAMP_V6}" -eq 1 ]]; then
    log "IPv6 MSS clamp: ${scope}"
    add_mss_if_absent ip6tables mangle FORWARD -p tcp --tcp-flags SYN,RST SYN -j TCPMSS --clamp-mss-to-pmtu
    if [[ "${MSS_CLAMP_HOST_OUTPUT}" -eq 1 ]]; then
      add_mss_if_absent ip6tables mangle OUTPUT -p tcp --tcp-flags SYN,RST SYN -j TCPMSS --clamp-mss-to-pmtu
    fi
  fi
}

cleanup_mss(){
  delete_mss_if_present iptables mangle FORWARD -p tcp --tcp-flags SYN,RST SYN -j TCPMSS --clamp-mss-to-pmtu
  delete_mss_if_present iptables mangle OUTPUT -p tcp --tcp-flags SYN,RST SYN -j TCPMSS --clamp-mss-to-pmtu
  delete_mss_if_present ip6tables mangle FORWARD -p tcp --tcp-flags SYN,RST SYN -j TCPMSS --clamp-mss-to-pmtu
  delete_mss_if_present ip6tables mangle OUTPUT -p tcp --tcp-flags SYN,RST SYN -j TCPMSS --clamp-mss-to-pmtu
}

show_qdisc_status(){
  echo
  echo "====== qdisc status ======"

  local dev ifb
  for dev in "${!CANDIDATES[@]}"; do
    echo "--- ${dev} ---"
    tc -s qdisc show dev "${dev}" | sed -n '1,160p' || true

    ifb="$(ifb_name "${dev}")"
    if ip link show "${ifb}" >/dev/null 2>&1; then
      echo "--- ${ifb} ---"
      tc -s qdisc show dev "${ifb}" | sed -n '1,160p' || true
    fi
  done
}

# ---------- bandwidth detect ----------
record_detect(){
  local method="$1"
  local up_mbit="$2"   # empty or integer Mbit
  local down_mbit="$3"
  local note="$4"

  DETECT_METHOD_NAMES+=("${method}")
  DETECT_UP_MBITS+=("${up_mbit}")
  DETECT_DOWN_MBITS+=("${down_mbit}")
  DETECT_NOTES+=("${note}")

  local up_s="${up_mbit:-n/a}" down_s="${down_mbit:-n/a}"
  [[ -n "${up_mbit}" ]] && up_s="${up_mbit} Mbit"
  [[ -n "${down_mbit}" ]] && down_s="${down_mbit} Mbit"
  log "Result [${method}]: up=${up_s}  down=${down_s}  (${note})"
}

# HTTP multi-URL download → downlink Mbit estimate
detect_http(){
  step "测速方法 http：多 URL 下载计时（会显示进度）"

  if ! have_bin curl && ! have_bin wget; then
    record_detect "http" "" "" "skipped: need curl or wget"
    return 0
  fi

  local urls="${HTTP_TEST_URLS//,/ }"
  local url best=0 got=0 mbit bytes secs tmp
  tmp="$(make_temp_file)"

  for url in ${urls}; do
    [[ -n "${url}" ]] || continue
    log "  downloading sample: ${url}"
    mbit=""
    if have_bin curl; then
      local meta
      # progress-bar → stderr；-w 指标 → stdout（只下一遍）
      if [[ "${LIVE_OUTPUT}" == "1" ]]; then
        meta="$(curl -L --max-time 45 -o "${tmp}" --progress-bar -w '%{size_download} %{time_total}' "${url}" || true)"
      else
        meta="$(curl -L --max-time 45 -o "${tmp}" -s -w '%{size_download} %{time_total}' "${url}" 2>/dev/null || true)"
      fi
      bytes="$(printf '%s' "${meta}" | awk '{print $1}')"
      secs="$(printf '%s' "${meta}" | awk '{print $2}')"
    else
      local start end
      start="$(date +%s.%N 2>/dev/null || date +%s)"
      if [[ "${LIVE_OUTPUT}" == "1" ]]; then
        wget -O "${tmp}" --timeout=45 --progress=bar:force "${url}" || true
      else
        wget -q -O "${tmp}" --timeout=45 "${url}" 2>/dev/null || true
      fi
      end="$(date +%s.%N 2>/dev/null || date +%s)"
      bytes="$(wc -c <"${tmp}" 2>/dev/null | tr -d ' ' || echo 0)"
      secs="$(awk -v s="${start}" -v e="${end}" 'BEGIN{d=e-s; if(d<=0) d=0.001; print d}')"
    fi

    if [[ -n "${bytes}" && -n "${secs}" ]]; then
      mbit="$(awk -v b="${bytes}" -v t="${secs}" 'BEGIN{
        if (t<=0 || b<500000) { print 0; exit }
        printf "%d", int((b*8)/(t*1000000)+0.5)
      }')"
      if [[ "${mbit}" -gt 5 ]]; then
        got=1
        best="$(max_int "${best}" "${mbit}")"
        log "  → ~${mbit} Mbit down (${bytes} bytes in ${secs}s)"
      else
        log "  → sample too small or too slow, ignored"
      fi
    fi
  done
  rm -f "${tmp}" 2>/dev/null || true

  if [[ "${got}" -eq 1 ]]; then
    record_detect "http" "" "${best}" "download peak across URLs"
  else
    record_detect "http" "" "" "no usable download sample"
  fi
}

# Auto-install speedtest / speedtest-cli on Debian/Ubuntu (and pip fallback)
ensure_speedtest_tools(){
  [[ "${AUTO_INSTALL_SPEEDTEST}" == "1" ]] || return 0
  if have_bin speedtest || have_bin speedtest-cli; then
    log "speedtest 工具已存在: $(command -v speedtest 2>/dev/null || true) $(command -v speedtest-cli 2>/dev/null || true)"
    return 0
  fi

  step "自动安装 speedtest 工具（用于上下行测速）"
  export DEBIAN_FRONTEND=noninteractive

  if have_bin apt-get; then
    log "  apt-get update (quiet)..."
    apt-get update -qq </dev/null 2>/dev/null || true
    log "  尝试: apt-get install -y speedtest-cli"
    apt-get install -y -qq speedtest-cli </dev/null 2>/dev/null || true
    if ! have_bin speedtest-cli && ! have_bin speedtest; then
      log "  尝试: apt-get install -y speedtest"
      apt-get install -y -qq speedtest </dev/null 2>/dev/null || true
    fi
  fi

  if ! have_bin speedtest && ! have_bin speedtest-cli && have_bin pip3; then
    log "  尝试: pip3 install speedtest-cli"
    pip3 install -q speedtest-cli </dev/null 2>/dev/null || \
      pip3 install -q --break-system-packages speedtest-cli </dev/null 2>/dev/null || true
  fi

  if ! have_bin speedtest && ! have_bin speedtest-cli && have_bin pip; then
    log "  尝试: pip install speedtest-cli"
    pip install -q speedtest-cli </dev/null 2>/dev/null || \
      pip install -q --break-system-packages speedtest-cli </dev/null 2>/dev/null || true
  fi

  if have_bin speedtest || have_bin speedtest-cli; then
    ok "speedtest 工具已就绪: $(command -v speedtest 2>/dev/null || command -v speedtest-cli)"
  else
    warn "无法自动安装 speedtest/speedtest-cli；将跳过 speedtest（可手动: apt-get install -y speedtest-cli）"
  fi
}

# speedtest-cli or official ookla speedtest
detect_speedtest(){
  step "测速方法 speedtest：本机 CLI（实时输出）"
  ensure_speedtest_tools

  local up="" down="" note="" out
  out="$(make_temp_file)"

  if have_bin speedtest; then
    log "  running: speedtest (live)..."
    set +e
    # Prefer human-readable live progress when LIVE_OUTPUT=1
    if [[ "${LIVE_OUTPUT}" == "1" ]]; then
      run_live "${out}" speedtest --accept-license --accept-gdpr --progress=yes
      down="$(grep -iE 'Download' "${out}" 2>/dev/null | grep -oE '[0-9]+(\.[0-9]+)?' | head -1 || true)"
      up="$(grep -iE 'Upload' "${out}" 2>/dev/null | grep -oE '[0-9]+(\.[0-9]+)?' | head -1 || true)"
      down="$(rate_to_mbit "${down}")"
      up="$(rate_to_mbit "${up}")"
      note="speedtest live"
    fi
    if [[ -z "${down}" && -z "${up}" ]]; then
      : >"${out}"
      run_live "${out}" speedtest --accept-license --accept-gdpr -f json
      if have_bin python3; then
        down="$(python3 -c 'import sys,json; d=json.load(open(sys.argv[1])); print(int(d["download"]["bandwidth"]*8/1e6+0.5))' "${out}" 2>/dev/null || true)"
        up="$(python3 -c 'import sys,json; d=json.load(open(sys.argv[1])); print(int(d["upload"]["bandwidth"]*8/1e6+0.5))' "${out}" 2>/dev/null || true)"
      fi
      note="ookla speedtest JSON"
    fi
    set -e
  fi

  if [[ -z "${down}" && -z "${up}" ]] && have_bin speedtest-cli; then
    log "  running: speedtest-cli --simple (live)..."
    set +e
    run_live "${out}" speedtest-cli --simple
    set -e
    down="$(grep -i Download "${out}" 2>/dev/null | grep -oE '[0-9]+(\.[0-9]+)?' | head -1 || true)"
    up="$(grep -i Upload "${out}" 2>/dev/null | grep -oE '[0-9]+(\.[0-9]+)?' | head -1 || true)"
    down="$(rate_to_mbit "${down}")"
    up="$(rate_to_mbit "${up}")"
    note="speedtest-cli"
  fi

  rm -f "${out}" 2>/dev/null || true

  if [[ -z "${down}" && -z "${up}" ]]; then
    record_detect "speedtest" "" "" "skipped: no speedtest CLI after auto-install attempt"
    return 0
  fi
  record_detect "speedtest" "${up}" "${down}" "${note:-speedtest}"
}

# Optional: kept for DETECT_METHODS=...,iperf3 manual use only (not in default list)
detect_iperf3(){
  step "测速方法 iperf3：点对点（默认已移除；需 IPERF3_SERVER）"

  if ! have_bin iperf3; then
    record_detect "iperf3" "" "" "skipped: iperf3 not installed"
    return 0
  fi
  if [[ -z "${IPERF3_SERVER}" ]]; then
    record_detect "iperf3" "" "" "skipped: set IPERF3_SERVER=host"
    return 0
  fi

  local dur="${IPERF3_DURATION:-8}"
  local out down="" up=""
  out="$(make_temp_file)"

  step "iperf3 下行 (-R) → ${IPERF3_SERVER}（${dur}s）"
  set +e
  run_live "${out}" iperf3 -c "${IPERF3_SERVER}" -t "${dur}" -R
  set -e
  # receiver bits/sec from summary line
  down="$(grep -iE 'receiver|sender' "${out}" 2>/dev/null | grep -oE '[0-9]+(\.[0-9]+)?' | tail -2 | head -1 || true)"
  # Mbits/sec line: prefer "Mbits/sec"
  local down_line
  down_line="$(grep -E 'bits/sec' "${out}" 2>/dev/null | grep -i receiver | tail -1 || true)"
  if [[ -n "${down_line}" ]]; then
    if echo "${down_line}" | grep -qiE 'Gbits'; then
      down="$(echo "${down_line}" | grep -oE '[0-9]+(\.[0-9]+)?' | head -1)"
      down="$(awk -v v="${down:-0}" 'BEGIN{printf "%d", int(v*1000+0.5)}')"
    else
      down="$(echo "${down_line}" | grep -oE '[0-9]+(\.[0-9]+)?' | head -1)"
      down="$(awk -v v="${down:-0}" 'BEGIN{printf "%d", int(v+0.5)}')"
    fi
  fi

  step "iperf3 上行 → ${IPERF3_SERVER}（${dur}s）"
  : >"${out}"
  set +e
  run_live "${out}" iperf3 -c "${IPERF3_SERVER}" -t "${dur}"
  set -e
  local up_line
  up_line="$(grep -E 'bits/sec' "${out}" 2>/dev/null | grep -i sender | tail -1 || true)"
  if [[ -n "${up_line}" ]]; then
    if echo "${up_line}" | grep -qiE 'Gbits'; then
      up="$(echo "${up_line}" | grep -oE '[0-9]+(\.[0-9]+)?' | head -1)"
      up="$(awk -v v="${up:-0}" 'BEGIN{printf "%d", int(v*1000+0.5)}')"
    else
      up="$(echo "${up_line}" | grep -oE '[0-9]+(\.[0-9]+)?' | head -1)"
      up="$(awk -v v="${up:-0}" 'BEGIN{printf "%d", int(v+0.5)}')"
    fi
  fi
  rm -f "${out}" 2>/dev/null || true

  if [[ -z "${up}" && -z "${down}" ]]; then
    record_detect "iperf3" "" "" "failed against ${IPERF3_SERVER}"
    return 0
  fi
  [[ "${up:-0}" -eq 0 ]] && up=""
  [[ "${down:-0}" -eq 0 ]] && down=""
  record_detect "iperf3" "${up}" "${down}" "server=${IPERF3_SERVER}"
}

# Optional remote bench: download to temp, run, parse Mbps-like numbers
detect_bench(){
  step "测速方法 bench：远程脚本（全程实时输出，可能需数分钟）"

  if [[ "${ALLOW_REMOTE_BENCH}" != "1" ]]; then
    if is_tty; then
      printf '[?] Run remote bench from %s ? This executes third-party code as root. [y/N] ' "${BENCH_URL}"
      local ans=""
      read -r ans || true
      case "${ans}" in
        y|Y|yes|YES) ;;
        *)
          record_detect "bench" "" "" "skipped: user declined remote bench"
          return 0
          ;;
      esac
    else
      record_detect "bench" "" "" "skipped: set ALLOW_REMOTE_BENCH=1"
      return 0
    fi
  fi

  if ! have_bin curl && ! have_bin wget; then
    record_detect "bench" "" "" "skipped: need curl or wget"
    return 0
  fi

  local work script out
  work="$(make_temp_dir)"
  script="${work}/bench.sh"
  out="${work}/out.txt"

  log "  fetching bench script from ${BENCH_URL}"
  log "  save to ${script}"
  if have_bin curl; then
    if [[ "${LIVE_OUTPUT}" == "1" ]]; then
      curl -fL --max-time 60 --progress-bar "${BENCH_URL}" -o "${script}" || {
        rm -rf "${work}" 2>/dev/null || true
        record_detect "bench" "" "" "download failed"
        return 0
      }
    else
      curl -fsSL --max-time 60 "${BENCH_URL}" -o "${script}" || {
        rm -rf "${work}" 2>/dev/null || true
        record_detect "bench" "" "" "download failed"
        return 0
      }
    fi
  else
    if [[ "${LIVE_OUTPUT}" == "1" ]]; then
      wget -O "${script}" --timeout=60 --progress=bar:force "${BENCH_URL}" || {
        rm -rf "${work}" 2>/dev/null || true
        record_detect "bench" "" "" "download failed"
        return 0
      }
    else
      wget -q -O "${script}" --timeout=60 "${BENCH_URL}" || {
        rm -rf "${work}" 2>/dev/null || true
        record_detect "bench" "" "" "download failed"
        return 0
      }
    fi
  fi

  if [[ ! -s "${script}" ]]; then
    rm -rf "${work}" 2>/dev/null || true
    record_detect "bench" "" "" "empty script"
    return 0
  fi

  chmod 0700 "${script}"
  log "  说明: 等价于 bench.sh 测速，但不用「wget|bash」裸管道（先下载再执行，可审计）"
  log "  开始执行 bench（输出会实时显示在下方，请勿中断）..."
  log "  日志同时写入: ${out}"
  echo "---------- bench live output begin ----------"
  set +e
  run_live "${out}" bash "${script}"
  set -e
  echo "---------- bench live output end ----------"
  log "  bench 进程结束，正在解析带宽数字..."

  # Parse common patterns: Download: xx.xx Mbps / 上行 / 下行 / Speed ...
  local down up
  down="$(grep -iE 'download|下行|接收' "${out}" 2>/dev/null | grep -oE '[0-9]+(\.[0-9]+)?' | head -1 || true)"
  up="$(grep -iE 'upload|上行|发送' "${out}" 2>/dev/null | grep -oE '[0-9]+(\.[0-9]+)?' | head -1 || true)"

  # Fallback: lines with Mbps
  if [[ -z "${down}" ]]; then
    down="$(grep -oiE '[0-9]+(\.[0-9]+)?[[:space:]]*Mbps' "${out}" 2>/dev/null | head -1 | grep -oE '[0-9]+(\.[0-9]+)?' || true)"
  fi
  if [[ -z "${up}" ]]; then
    up="$(grep -oiE '[0-9]+(\.[0-9]+)?[[:space:]]*Mbps' "${out}" 2>/dev/null | sed -n '2p' | grep -oE '[0-9]+(\.[0-9]+)?' || true)"
  fi

  down="$(rate_to_mbit "${down}")"
  up="$(rate_to_mbit "${up}")"

  # Parse fail: keep short snippet in cache (not /tmp for 60s), then delete workdir
  if [[ -z "${up}" && -z "${down}" ]]; then
    mkdir -p "${CACHE_DIR}" 2>/dev/null || true
    {
      echo "# bench parse failed $(date -Is 2>/dev/null || date)"
      tail -n 80 "${out}" 2>/dev/null || true
    } >"${BENCH_FAIL_SNIPPET}" 2>/dev/null || true
    warn "bench 无法解析带宽；摘要已写入 ${BENCH_FAIL_SNIPPET}，临时目录立即删除"
    rm -rf "${work}" 2>/dev/null || true
    record_detect "bench" "" "" "parse failed (snippet in cache)"
    return 0
  fi

  rm -rf "${work}" 2>/dev/null || true
  record_detect "bench" "${up}" "${down}" "remote ${BENCH_URL}"
}

# Optional rough RTT → suggest CAKE_RTT if still default-ish
suggest_rtt_from_ping(){
  local host="${1:-1.1.1.1}"
  if ! have_bin ping; then
    return 0
  fi
  local out rtt
  out="$(ping -c 4 -W 2 "${host}" 2>/dev/null || true)"
  rtt="$(printf '%s' "${out}" | awk -F'/' '/rtt|round-trip/{print $5; exit}')"
  if [[ -z "${rtt}" ]]; then
    rtt="$(printf '%s' "${out}" | awk -F'=' '/time=/{gsub(/ ms/,""); print $NF}' | awk '{s+=$1;n++} END{if(n) print s/n}')"
  fi
  [[ -n "${rtt}" ]] || return 0
  # map avg rtt to cake rtt with floor/ceil
  local ms
  ms="$(awk -v r="${rtt}" 'BEGIN{
    m=int(r*1.5+0.5)
    if (m<20) m=20
    if (m>250) m=250
    print m
  }')"
  printf '%sms' "${ms}"
}

# Count how many positive samples we have in each direction
count_detect_samples(){
  local i n="${#DETECT_METHOD_NAMES[@]}" up=0 down=0
  for ((i=0; i<n; i++)); do
    [[ -n "${DETECT_UP_MBITS[i]:-}" && "${DETECT_UP_MBITS[i]}" -gt 0 ]] && up=$((up+1))
    [[ -n "${DETECT_DOWN_MBITS[i]:-}" && "${DETECT_DOWN_MBITS[i]}" -gt 0 ]] && down=$((down+1))
  done
  printf '%s %s' "${up}" "${down}"
}

run_all_detect_methods(){
  DETECT_METHOD_NAMES=()
  DETECT_UP_MBITS=()
  DETECT_DOWN_MBITS=()
  DETECT_NOTES=()

  local methods="${DETECT_METHODS//,/ }"
  local m
  local list=()
  for m in ${methods}; do
    m="$(printf '%s' "${m}" | tr '[:upper:]' '[:lower:]' | tr -d ' ')"
    [[ -n "${m}" ]] || continue
    # strip default iperf3 if user didn't set server (avoid noise)
    if [[ "${m}" == "iperf3" || "${m}" == "iperf" ]]; then
      if [[ -z "${IPERF3_SERVER:-}" ]]; then
        log "忽略方法 iperf3（默认已移除；需要时设 IPERF3_SERVER=对端 并 DETECT_METHODS=...,iperf3）"
        continue
      fi
    fi
    list+=("${m}")
  done

  # 测速前：自动安装 speedtest CLI（若计划跑 speedtest）
  for m in "${list[@]}"; do
    if [[ "${m}" == "speedtest" || "${m}" == "st" ]]; then
      ensure_speedtest_tools
      break
    fi
  done

  # 列表含 bench 时确保允许远程（仍走下载到文件，非裸管道）
  for m in "${list[@]}"; do
    if [[ "${m}" == "bench" || "${m}" == "benchsh" ]]; then
      if [[ -z "${OVERRIDE_ALLOW_REMOTE_BENCH:-}" ]]; then
        ALLOW_REMOTE_BENCH=1
      fi
      break
    fi
  done

  local rounds="${DETECT_ROUNDS:-1}"
  [[ "${rounds}" -ge 1 ]] || rounds=1
  [[ "${rounds}" -le 5 ]] || rounds=5
  local need="${EARLY_STOP_SAMPLES:-2}"
  [[ "${need}" -ge 1 ]] || need=2

  local total_steps=0 r
  for ((r=1; r<=rounds; r++)); do
    for m in "${list[@]}"; do
      if [[ "${m}" == "bench" || "${m}" == "benchsh" ]] && [[ "${r}" -gt 1 ]]; then
        continue
      fi
      total_steps=$((total_steps + 1))
    done
  done

  local idx=0
  log "测速计划: methods=${list[*]}  rounds=${rounds}  early_stop≥${need}样本/向  LIVE=${LIVE_OUTPUT}"
  log "聚合=${AGGREGATE_MODE}  安全系数=${BANDWIDTH_SAFETY_FACTOR}  AUTO_INSTALL_SPEEDTEST=${AUTO_INSTALL_SPEEDTEST}"

  for ((r=1; r<=rounds; r++)); do
    step "测速轮次 ${r}/${rounds}"
    for m in "${list[@]}"; do
      if [[ "${m}" == "bench" || "${m}" == "benchsh" ]] && [[ "${r}" -gt 1 ]]; then
        log "跳过 bench 第 ${r} 轮（只跑第1轮，耗时长）"
        continue
      fi
      # early stop: enough samples already (both directions)
      local sc up_n down_n
      sc="$(count_detect_samples)"
      up_n="${sc%% *}"
      down_n="${sc##* }"
      if [[ "${up_n}" -ge "${need}" && "${down_n}" -ge "${need}" ]]; then
        ok "已有足够样本 up=${up_n} down=${down_n} (≥${need}) → 提前结束后续测速"
        return 0
      fi
      idx=$((idx + 1))
      progress_set "${idx}" "${total_steps}" "测速 ${m} (轮${r}/${rounds})" "method=${m} round=${r}"
      case "${m}" in
        http) detect_http ;;
        speedtest|st) detect_speedtest ;;
        iperf3|iperf) detect_iperf3 ;;
        bench|benchsh) detect_bench ;;
        *) warn "Unknown detect method: ${m}" ;;
      esac
      if [[ ${#DETECT_NOTES[@]} -gt 0 ]]; then
        local li=$((${#DETECT_NOTES[@]} - 1))
        DETECT_NOTES[li]="${DETECT_NOTES[li]} r${r}"
      fi
      ok "完成 ${idx}/${total_steps}: ${m} 轮${r}"
    done
  done

  # Fallback bench once if no usable samples and bench wasn't already run
  local sc2 u2 d2 had_bench=0
  sc2="$(count_detect_samples)"
  u2="${sc2%% *}"
  d2="${sc2##* }"
  for m in "${list[@]}"; do
    [[ "${m}" == "bench" || "${m}" == "benchsh" ]] && had_bench=1
  done
  if [[ "${u2}" -eq 0 && "${d2}" -eq 0 && "${AUTO_BENCH_FALLBACK}" == "1" && "${had_bench}" -eq 0 ]]; then
    warn "主测速无可用样本 → fallback 运行一次 bench（下载 bench.sh 后执行，非裸管道）"
    local old_allow="${ALLOW_REMOTE_BENCH}"
    ALLOW_REMOTE_BENCH=1
    progress_set "F" "F" "fallback bench" "AUTO_BENCH_FALLBACK"
    detect_bench
    ALLOW_REMOTE_BENCH="${old_allow}"
  fi
}

aggregate_peaks(){
  PEAK_UP_MBIT=""
  PEAK_DOWN_MBIT=""
  local i n="${#DETECT_METHOD_NAMES[@]}"
  local up down
  local -a ups=() downs=()
  local max_up=0 max_down=0 min_up="" min_down=""

  for ((i=0; i<n; i++)); do
    up="${DETECT_UP_MBITS[i]:-}"
    down="${DETECT_DOWN_MBITS[i]:-}"
    if [[ -n "${up}" && "${up}" =~ ^[0-9]+$ && "${up}" -gt 0 ]]; then
      ups+=("${up}")
      max_up="$(max_int "${max_up}" "${up}")"
      if [[ -z "${min_up}" ]]; then min_up="${up}"; else min_up="$(min_int "${min_up}" "${up}")"; fi
    fi
    if [[ -n "${down}" && "${down}" =~ ^[0-9]+$ && "${down}" -gt 0 ]]; then
      downs+=("${down}")
      max_down="$(max_int "${max_down}" "${down}")"
      if [[ -z "${min_down}" ]]; then min_down="${down}"; else min_down="$(min_int "${min_down}" "${down}")"; fi
    fi
  done

  local mode="${AGGREGATE_MODE:-median}"
  case "${mode}" in
    max|peak)
      [[ "${#ups[@]}" -gt 0 ]] && PEAK_UP_MBIT="${max_up}"
      [[ "${#downs[@]}" -gt 0 ]] && PEAK_DOWN_MBIT="${max_down}"
      ;;
    min|conservative)
      [[ -n "${min_up}" ]] && PEAK_UP_MBIT="${min_up}"
      [[ -n "${min_down}" ]] && PEAK_DOWN_MBIT="${min_down}"
      ;;
    median|*)
      PEAK_UP_MBIT="$(median_int "${ups[@]}")"
      PEAK_DOWN_MBIT="$(median_int "${downs[@]}")"
      ;;
  esac

  log "聚合[${mode}] 原始 up=${PEAK_UP_MBIT:-n/a} down=${PEAK_DOWN_MBIT:-n/a} (样本 up=${#ups[@]} down=${#downs[@]})"

  # Cap measured peak before applying safety (防止 10G 虚高)
  if [[ -n "${PEAK_UP_MBIT}" ]]; then
    PEAK_UP_MBIT="$(cap_mbit "${PEAK_UP_MBIT}" up)"
  fi
  if [[ -n "${PEAK_DOWN_MBIT}" ]]; then
    PEAK_DOWN_MBIT="$(cap_mbit "${PEAK_DOWN_MBIT}" down)"
  fi

  SUGGEST_UP=""
  SUGGEST_DOWN=""
  [[ -n "${PEAK_UP_MBIT}" ]] && SUGGEST_UP="$(mbit_with_safety "${PEAK_UP_MBIT}")"
  [[ -n "${PEAK_DOWN_MBIT}" ]] && SUGGEST_DOWN="$(mbit_with_safety "${PEAK_DOWN_MBIT}")"
}

print_detect_table(){
  echo
  echo "====== detect summary ======"
  printf '%-14s  %-12s  %-12s  %s\n' "METHOD" "UP (Mbit)" "DOWN (Mbit)" "NOTE"
  printf '%-14s  %-12s  %-12s  %s\n' "--------------" "------------" "------------" "----"
  local i n="${#DETECT_METHOD_NAMES[@]}"
  for ((i=0; i<n; i++)); do
    printf '%-14s  %-12s  %-12s  %s\n' \
      "${DETECT_METHOD_NAMES[i]}" \
      "${DETECT_UP_MBITS[i]:-n/a}" \
      "${DETECT_DOWN_MBITS[i]:-n/a}" \
      "${DETECT_NOTES[i]:-}"
  done
  echo
  echo "Aggregate:  ${AGGREGATE_MODE}  (not raw max unless mode=max)"
  echo "Peak up:    ${PEAK_UP_MBIT:-n/a} Mbit (after caps)"
  echo "Peak down:  ${PEAK_DOWN_MBIT:-n/a} Mbit (after caps)"
  echo "Safety:     × ${BANDWIDTH_SAFETY_FACTOR}"
  echo "MAX_UP:     ${MAX_UP_RATE:-cpu-soft/${CPU_CAP_RATES}}  MAX_DOWN: ${MAX_DOWN_RATE:-cpu-soft/${CPU_CAP_RATES}}"
  echo "Suggest:    UP_RATE=${SUGGEST_UP:-unset}  DOWN_RATE=${SUGGEST_DOWN:-unset}"
  echo
  echo "Note: 测速=路径/时段估计，≠合同带宽；CAKE 必须低于真实瓶颈。"
}

save_detect_cache(){
  mkdir -p "$(dirname "${DETECT_CACHE_FILE}")"
  cat >"${DETECT_CACHE_FILE}" <<EOF
# generated by bbr-cake-transit-exit detect $(date -Is 2>/dev/null || date)
PEAK_UP_MBIT="${PEAK_UP_MBIT:-}"
PEAK_DOWN_MBIT="${PEAK_DOWN_MBIT:-}"
SUGGEST_UP="${SUGGEST_UP:-}"
SUGGEST_DOWN="${SUGGEST_DOWN:-}"
BANDWIDTH_SAFETY_FACTOR="${BANDWIDTH_SAFETY_FACTOR}"
BANDWIDTH_SOURCE="detect"
DETECT_METHODS="${DETECT_METHODS}"
EOF
  ok "Saved detect cache: ${DETECT_CACHE_FILE}"
}

load_detect_cache(){
  [[ "${USE_DETECT_CACHE}" == "1" ]] || return 1
  [[ -f "${DETECT_CACHE_FILE}" ]] || return 1
  # shellcheck disable=SC1090
  . "${DETECT_CACHE_FILE}"
  [[ -n "${SUGGEST_UP:-}" || -n "${SUGGEST_DOWN:-}" ]] || return 1
  return 0
}

confirm_peak_rates(){
  # Sets BANDWIDTH_UP_DEFAULT, BANDWIDTH_DOWN_DEFAULT, ENABLE_LIMITS, BANDWIDTH_SOURCE
  if [[ -z "${SUGGEST_UP:-}" && -z "${SUGGEST_DOWN:-}" ]]; then
    warn "No usable peak rates from detect."
    if [[ "${AUTO_CONFIRM_PEAK}" == "1" ]]; then
      ENABLE_LIMITS=0
      BANDWIDTH_SOURCE="none"
      return 0
    fi
    if is_tty; then
      printf '[?] No peaks found. Continue with unlimited CAKE (no hard limit)? [Y/n] '
      local ans=""
      read -r ans || true
      case "${ans}" in
        n|N|no|NO)
          die "Aborted: no bandwidth rates."
          ;;
        *)
          ENABLE_LIMITS=0
          BANDWIDTH_SOURCE="none"
          return 0
          ;;
      esac
    else
      ENABLE_LIMITS=0
      BANDWIDTH_SOURCE="none"
      return 0
    fi
  fi

  local use_up="${SUGGEST_UP:-}"
  local use_down="${SUGGEST_DOWN:-}"

  if [[ "${AUTO_CONFIRM_PEAK}" == "1" ]]; then
    log "AUTO_CONFIRM_PEAK=1 → accept suggest UP=${use_up:-none} DOWN=${use_down:-none}"
  elif is_tty; then
    echo
    printf '[?] Accept suggested rates UP=%s DOWN=%s ?\n' "${use_up:-none}" "${use_down:-none}"
    printf '    [Y] accept  [E] edit manually  [N] no limit (AQM only)  [Q] quit: '
    local ans=""
    read -r ans || true
    case "${ans}" in
      ""|y|Y|yes|YES) ;;
      e|E)
        printf '    UP_RATE (e.g. 90Mbit, empty=skip): '
        read -r use_up || true
        printf '    DOWN_RATE (e.g. 900Mbit, empty=skip): '
        read -r use_down || true
        ;;
      n|N|no|NO)
        ENABLE_LIMITS=0
        BANDWIDTH_SOURCE="none"
        BANDWIDTH_UP_DEFAULT=""
        BANDWIDTH_DOWN_DEFAULT=""
        ok "Will apply CAKE without hard bandwidth limits."
        return 0
        ;;
      q|Q)
        die "Aborted by user."
        ;;
      *)
        warn "Unknown choice, accepting suggest."
        ;;
    esac
  else
    warn "Non-interactive shell: accepting suggested rates (set AUTO_CONFIRM_PEAK=1 to silence)."
  fi

  BANDWIDTH_UP_DEFAULT="${use_up}"
  BANDWIDTH_DOWN_DEFAULT="${use_down}"
  if [[ -n "${BANDWIDTH_UP_DEFAULT}" || -n "${BANDWIDTH_DOWN_DEFAULT}" ]]; then
    ENABLE_LIMITS=1
    BANDWIDTH_SOURCE="detect"
  else
    ENABLE_LIMITS=0
    BANDWIDTH_SOURCE="none"
  fi
  # Asymmetric: if only one side set, still enable limits for that side in apply_qdisc
  ok "Using UP_RATE=${BANDWIDTH_UP_DEFAULT:-unlimited} DOWN_RATE=${BANDWIDTH_DOWN_DEFAULT:-unlimited}"
}

resolve_bandwidth(){
  # Priority: explicit rates → env file already loaded → cache → auto detect → unlimited
  local cli_up="${OVERRIDE_UP_RATE:-${OVERRIDE_BANDWIDTH_UP_DEFAULT:-}}"
  local cli_down="${OVERRIDE_DOWN_RATE:-${OVERRIDE_BANDWIDTH_DOWN_DEFAULT:-}}"

  if [[ -n "${cli_up}" || -n "${cli_down}" ]]; then
    BANDWIDTH_UP_DEFAULT="${cli_up:-${BANDWIDTH_UP_DEFAULT:-}}"
    BANDWIDTH_DOWN_DEFAULT="${cli_down:-${BANDWIDTH_DOWN_DEFAULT:-}}"
    ENABLE_LIMITS="${OVERRIDE_ENABLE_LIMITS:-1}"
    BANDWIDTH_SOURCE="manual"
    log "Bandwidth source: manual (UP=${BANDWIDTH_UP_DEFAULT:-unset} DOWN=${BANDWIDTH_DOWN_DEFAULT:-unset})"
    return 0
  fi

  # Rates already in env file (from previous install)
  if [[ -n "${BANDWIDTH_UP_DEFAULT}" || -n "${BANDWIDTH_DOWN_DEFAULT}" ]]; then
    if [[ -z "${ENABLE_LIMITS}" ]]; then
      ENABLE_LIMITS=1
    fi
    if [[ "${BANDWIDTH_SOURCE}" == "none" || -z "${BANDWIDTH_SOURCE}" ]]; then
      BANDWIDTH_SOURCE="config"
    fi
    log "Bandwidth source: ${BANDWIDTH_SOURCE} (UP=${BANDWIDTH_UP_DEFAULT:-unset} DOWN=${BANDWIDTH_DOWN_DEFAULT:-unset})"
    return 0
  fi

  if [[ "${AUTO_DETECT_BW}" == "1" ]]; then
    log "AUTO_DETECT_BW=1 → running multi-method detect"
    run_all_detect_methods
    aggregate_peaks
    print_detect_table
    save_detect_cache
    confirm_peak_rates
    return 0
  fi

  if load_detect_cache; then
    BANDWIDTH_UP_DEFAULT="${SUGGEST_UP:-}"
    BANDWIDTH_DOWN_DEFAULT="${SUGGEST_DOWN:-}"
    ENABLE_LIMITS="${OVERRIDE_ENABLE_LIMITS:-1}"
    BANDWIDTH_SOURCE="detect-cache"
    log "Bandwidth source: detect-cache (UP=${BANDWIDTH_UP_DEFAULT:-unset} DOWN=${BANDWIDTH_DOWN_DEFAULT:-unset})"
    log "Re-run '$0 detect' to refresh peaks."
    return 0
  fi

  # Safe default: no hardcode 285/950
  if [[ -z "${ENABLE_LIMITS}" ]]; then
    ENABLE_LIMITS=0
  fi
  if [[ "${ENABLE_LIMITS}" == "1" ]]; then
    warn "ENABLE_LIMITS=1 but no UP/DOWN rates set; forcing unlimited to avoid wrong shape."
    ENABLE_LIMITS=0
  fi
  BANDWIDTH_SOURCE="none"
  warn "No bandwidth rates configured. Applying BBR+CAKE without hard limits."
  warn "Tip: run '$0 detect' or set UP_RATE/DOWN_RATE before apply."
}

# Force non-interactive peak acceptance and fill BANDWIDTH_* from detect results
accept_suggest_rates(){
  AUTO_CONFIRM_PEAK=1
  confirm_peak_rates
  if [[ -n "${BANDWIDTH_UP_DEFAULT:-}" || -n "${BANDWIDTH_DOWN_DEFAULT:-}" ]]; then
    mkdir -p "$(dirname "${DETECT_CACHE_FILE}")"
    cat >"${DETECT_CACHE_FILE}" <<EOF
# auto-filled $(date -Is 2>/dev/null || date)
PEAK_UP_MBIT="${PEAK_UP_MBIT:-}"
PEAK_DOWN_MBIT="${PEAK_DOWN_MBIT:-}"
SUGGEST_UP="${BANDWIDTH_UP_DEFAULT:-}"
SUGGEST_DOWN="${BANDWIDTH_DOWN_DEFAULT:-}"
BANDWIDTH_SAFETY_FACTOR="${BANDWIDTH_SAFETY_FACTOR}"
BANDWIDTH_SOURCE="detect"
DETECT_METHODS="${DETECT_METHODS}"
EOF
  fi
}

# Back-compat alias
maybe_auto_rtt(){ resolve_cake_rtt; }

run_detect_pipeline(){
  local retain_on_fail="${1:-0}"  # 1=retune: keep previous rates if all methods fail

  echo "====== auto bandwidth detect v${VERSION} ======"
  echo "Methods: ${DETECT_METHODS}"
  echo "Rounds: ${DETECT_ROUNDS}  Aggregate: ${AGGREGATE_MODE}"
  echo "Safety factor: ${BANDWIDTH_SAFETY_FACTOR}  (生产默认 0.85)"
  echo "Live output: LIVE_OUTPUT=${LIVE_OUTPUT}"
  echo "Non-interactive: 中位/聚合值 × factor → CAKE bandwidth"
  echo "This will saturate the link for a while."
  echo

  run_all_detect_methods

  step "汇总样本（${AGGREGATE_MODE}）→ 上限保护 → ×${BANDWIDTH_SAFETY_FACTOR}"
  aggregate_peaks
  print_detect_table
  resolve_cake_rtt

  if [[ -z "${PEAK_UP_MBIT:-}" && -z "${PEAK_DOWN_MBIT:-}" ]]; then
    warn "All detect methods failed or were skipped."
    post_detect_housekeeping
    if [[ "${retain_on_fail}" == "1" ]]; then
      warn "保留已有限速配置，不覆盖（retune 失败保护）"
      return 1
    fi
    warn "Will apply BBR+CAKE without hard bandwidth limits."
    ENABLE_LIMITS=0
    BANDWIDTH_SOURCE="none"
    BANDWIDTH_UP_DEFAULT=""
    BANDWIDTH_DOWN_DEFAULT=""
    return 0
  fi

  # If only one direction measured, mirror the other for shaping usability on 中转
  if [[ -n "${PEAK_DOWN_MBIT:-}" && -z "${PEAK_UP_MBIT:-}" ]]; then
    PEAK_UP_MBIT="${PEAK_DOWN_MBIT}"
    log "Only down measured → mirror peak up=${PEAK_UP_MBIT} Mbit for CAKE egress"
  fi
  if [[ -n "${PEAK_UP_MBIT:-}" && -z "${PEAK_DOWN_MBIT:-}" ]]; then
    PEAK_DOWN_MBIT="${PEAK_UP_MBIT}"
    log "Only up measured → mirror peak down=${PEAK_DOWN_MBIT} Mbit for CAKE ingress"
  fi
  # recompute suggest after mirror (cap already applied on peaks)
  SUGGEST_UP="$(mbit_with_safety "${PEAK_UP_MBIT}")"
  SUGGEST_DOWN="$(mbit_with_safety "${PEAK_DOWN_MBIT}")"
  echo "Final suggest after mirror: UP=${SUGGEST_UP} DOWN=${SUGGEST_DOWN}"

  save_detect_cache
  accept_suggest_rates
  # Normalize & validate filled rates
  if [[ -n "${BANDWIDTH_UP_DEFAULT:-}" ]]; then
    BANDWIDTH_UP_DEFAULT="$(normalize_cake_rate "${BANDWIDTH_UP_DEFAULT}")"
    is_valid_cake_rate "${BANDWIDTH_UP_DEFAULT}" || { warn "丢弃无效 UP ${BANDWIDTH_UP_DEFAULT}"; BANDWIDTH_UP_DEFAULT=""; }
  fi
  if [[ -n "${BANDWIDTH_DOWN_DEFAULT:-}" ]]; then
    BANDWIDTH_DOWN_DEFAULT="$(normalize_cake_rate "${BANDWIDTH_DOWN_DEFAULT}")"
    is_valid_cake_rate "${BANDWIDTH_DOWN_DEFAULT}" || { warn "丢弃无效 DOWN ${BANDWIDTH_DOWN_DEFAULT}"; BANDWIDTH_DOWN_DEFAULT=""; }
  fi
  if [[ -n "${BANDWIDTH_UP_DEFAULT:-}" || -n "${BANDWIDTH_DOWN_DEFAULT:-}" ]]; then
    ENABLE_LIMITS=1
  fi
  ok "带宽已自动填入: UP=${BANDWIDTH_UP_DEFAULT:-none} DOWN=${BANDWIDTH_DOWN_DEFAULT:-none} limits=${ENABLE_LIMITS}"
  post_detect_housekeeping
  return 0
}

persist_install(){
  install_self
  write_env_file
  write_service_file
  write_retune_units

  if have_bin systemctl; then
    systemctl daemon-reload
    systemctl enable "${SERVICE_NAME}" >/dev/null
    # apply already done; just enable for reboot — restart would re-apply
    systemctl restart "${SERVICE_NAME}" || true
    ok "Installed and enabled ${SERVICE_NAME}."
    if [[ "${DAILY_RETEST}" == "1" ]]; then
      systemctl enable --now "${RETUNE_TIMER_NAME}" >/dev/null 2>&1 || \
        systemctl enable "${RETUNE_TIMER_NAME}" >/dev/null 2>&1 || true
      systemctl start "${RETUNE_TIMER_NAME}" 2>/dev/null || true
      ok "Daily retune timer enabled (北京时间 ${RETEST_HOUR}:$(printf '%02d' "${RETEST_MINUTE}") Asia/Shanghai)"
      systemctl list-timers "${RETUNE_TIMER_NAME}" --no-pager 2>/dev/null || true
    else
      systemctl disable --now "${RETUNE_TIMER_NAME}" 2>/dev/null || true
      log "DAILY_RETEST=0 → 未启用每日重测"
    fi
  else
    warn "systemctl not found; files written but service not enabled."
  fi
  echo "[CONFIG] ${ENV_FILE}"
  echo "[SCRIPT] ${INSTALL_PATH}"
  echo "[SERVICE] ${SERVICE_FILE}"
  echo "[TIMER] ${RETUNE_TIMER_FILE} (DAILY_RETEST=${DAILY_RETEST})"
  echo "[BW] source=${BANDWIDTH_SOURCE} UP=${BANDWIDTH_UP_DEFAULT:-none} DOWN=${BANDWIDTH_DOWN_DEFAULT:-none} limits=${ENABLE_LIMITS}"
  echo "[LOG] ${RETUNE_LOG_FILE}"
  echo "[PROGRESS] ${PROGRESS_FILE}"
}

# One-shot: detect → auto-fill → apply → install (default entry)
auto_cmd(){
  require_root
  load_overrides

  # Fully automatic: no prompts
  AUTO_CONFIRM_PEAK=1
  # Do NOT force remote bench by default (security). AUTO_BENCH_FALLBACK handles shortage.

  echo "=============================================="
  echo " BBR+CAKE 中转一键调优 v${VERSION} (Transit + Region)"
  echo " 测速×${DETECT_ROUNDS}轮/${AGGREGATE_MODE} → ×safety → 应用 → 持久化"
  echo " 地区 REGION=${REGION} GEO_DETECT=${GEO_DETECT} | LIVE_OUTPUT=${LIVE_OUTPUT}"
  echo " 每日重测 DAILY_RETEST=${DAILY_RETEST} (北京 ${RETEST_HOUR}:$(printf '%02d' "${RETEST_MINUTE:-0}"))"
  echo "=============================================="
  echo
  echo "总流程预告:"
  echo "  阶段 1/5  环境检查"
  echo "  阶段 2/5  多轮测速 → ${AGGREGATE_MODE} → ×${BANDWIDTH_SAFETY_FACTOR} + 上限"
  echo "  阶段 3/5  CPU/RTT 策略"
  echo "  阶段 4/5  应用 BBR + CAKE"
  echo "  阶段 5/5  安装 systemd + 北京时间每日重测"
  echo "进度文件: ${PROGRESS_FILE}"
  echo

  progress_set 1 5 "环境检查 + 地区识别"
  log "开始 preflight（若此处退出会打印 [ERROR] 行号）..."
  preflight
  log "开始地区识别 REGION=${REGION} GEO_DETECT=${GEO_DETECT}..."
  resolve_region_tuning || warn "地区识别返回非零，继续使用当前参数"
  ok "环境检查通过 profile=${REGION_PROFILE:-?} RTT=${CAKE_RTT} safety=${BANDWIDTH_SAFETY_FACTOR}"

  local has_cli_rates=0
  if [[ -n "${OVERRIDE_UP_RATE:-}" || -n "${OVERRIDE_DOWN_RATE:-}" || \
        -n "${OVERRIDE_BANDWIDTH_UP_DEFAULT:-}" || -n "${OVERRIDE_BANDWIDTH_DOWN_DEFAULT:-}" ]]; then
    has_cli_rates=1
  fi

  progress_set 2 5 "多轮测速并自动填带宽" "factor=${BANDWIDTH_SAFETY_FACTOR} mode=${AGGREGATE_MODE}"
  if [[ "${SKIP_DETECT}" == "1" || "${has_cli_rates}" -eq 1 ]]; then
    if [[ "${has_cli_rates}" -eq 1 ]]; then
      BANDWIDTH_UP_DEFAULT="${OVERRIDE_UP_RATE:-${OVERRIDE_BANDWIDTH_UP_DEFAULT:-${BANDWIDTH_UP_DEFAULT:-}}}"
      BANDWIDTH_DOWN_DEFAULT="${OVERRIDE_DOWN_RATE:-${OVERRIDE_BANDWIDTH_DOWN_DEFAULT:-${BANDWIDTH_DOWN_DEFAULT:-}}}"
      ENABLE_LIMITS="${OVERRIDE_ENABLE_LIMITS:-1}"
      BANDWIDTH_SOURCE="manual"
      log "Skip detect: using manual rates UP=${BANDWIDTH_UP_DEFAULT:-unset} DOWN=${BANDWIDTH_DOWN_DEFAULT:-unset}"
    else
      resolve_bandwidth
    fi
  else
    BANDWIDTH_UP_DEFAULT=""
    BANDWIDTH_DOWN_DEFAULT=""
    run_detect_pipeline 0 || true
  fi
  ok "阶段 2/5 完成"

  progress_set 3 5 "CPU / RTT 自适应"
  resolve_cake_rtt
  maybe_adjust_ingress_for_cpu
  ok "阶段 3/5 完成 CAKE_RTT=${CAKE_RTT} ingress=${ENABLE_INGRESS_SHAPING}"

  progress_set 4 5 "应用 BBR + CAKE"
  step "写入 sysctl / 发现网卡 / 配置 qdisc / MSS"
  write_sysctl
  detect_cake_nat
  discover_candidates
  apply_qdisc
  apply_mss
  show_qdisc_status
  echo
  ok "Applied (source=${BANDWIDTH_SOURCE}, limits=${ENABLE_LIMITS}, UP=${BANDWIDTH_UP_DEFAULT:-none}, DOWN=${BANDWIDTH_DOWN_DEFAULT:-none})."
  ok "阶段 4/5 完成"

  progress_set 5 5 "安装 systemd + 每日重测定时器"
  if [[ "${AUTO_INSTALL}" == "1" ]]; then
    step "写入单元、enable、retune timer"
    persist_install
  else
    warn "AUTO_INSTALL=0 → not writing systemd unit. Reboot will lose tc rules."
    echo "[NOTE] Run: $0 install   later if needed."
  fi
  ok "阶段 5/5 完成"

  # Final temp/log housekeeping (idempotent if detect already cleaned)
  cleanup_temps quiet 2>/dev/null || true
  rotate_retune_log

  progress_done 5 "一键调优完成"
  echo
  echo "══════════════════════════════════════════════"
  ok "一键调优全部完成 (v${VERSION})"
  echo "══════════════════════════════════════════════"
  echo "查看状态: $0 status"
  echo "看进度:   cat ${PROGRESS_FILE}"
  echo "手动重测: $0 retune"
  echo "卸载:     $0 uninstall"
  echo "仅清运行时规则: $0 cleanup   (保留配置/服务/限速参数文件)"
}

# Nightly / manual re-detect and re-apply (keeps previous rates if detect fails)
retune_cmd(){
  require_root
  load_overrides
  AUTO_CONFIRM_PEAK=1
  if [[ -z "${OVERRIDE_ALLOW_REMOTE_BENCH}" ]]; then
    # retune: allow bench only if already enabled in env
    :
  fi

  mkdir -p "${RETUNE_LOG_DIR}" "$(dirname "${PROGRESS_FILE}")"
  local ts
  ts="$(TZ=Asia/Shanghai date '+%Y-%m-%d %H:%M:%S CST' 2>/dev/null || date)"

  {
    echo
    echo "########## retune start ${ts} v${VERSION} ##########"
    progress_set 1 4 "每日重测-环境检查" "beijing=${ts}"
    preflight

    progress_set 2 4 "每日重测-测速填带宽" "rounds=${DETECT_ROUNDS}"
    # Keep existing rates in memory as fallback
    local prev_up="${BANDWIDTH_UP_DEFAULT:-}" prev_down="${BANDWIDTH_DOWN_DEFAULT:-}" prev_lim="${ENABLE_LIMITS:-}"
    BANDWIDTH_UP_DEFAULT=""
    BANDWIDTH_DOWN_DEFAULT=""
    if ! run_detect_pipeline 1; then
      BANDWIDTH_UP_DEFAULT="${prev_up}"
      BANDWIDTH_DOWN_DEFAULT="${prev_down}"
      ENABLE_LIMITS="${prev_lim:-1}"
      BANDWIDTH_SOURCE="retain"
      warn "测速失败，保留: UP=${BANDWIDTH_UP_DEFAULT:-none} DOWN=${BANDWIDTH_DOWN_DEFAULT:-none}"
    fi

    progress_set 3 4 "每日重测-CPU/RTT/应用"
    resolve_cake_rtt
    maybe_adjust_ingress_for_cpu
    write_sysctl
    detect_cake_nat
    discover_candidates
    apply_qdisc
    apply_mss
    write_env_file

    progress_set 4 4 "每日重测-完成"
    show_qdisc_status
    cleanup_temps quiet 2>/dev/null || true
    rotate_retune_log
    ok "retune done UP=${BANDWIDTH_UP_DEFAULT:-none} DOWN=${BANDWIDTH_DOWN_DEFAULT:-none} rtt=${CAKE_RTT} ingress=${ENABLE_INGRESS_SHAPING}"
    echo "########## retune end $(TZ=Asia/Shanghai date '+%Y-%m-%d %H:%M:%S' 2>/dev/null || date) ##########"
  } 2>&1 | tee -a "${RETUNE_LOG_FILE}"
  # outer rotate after tee flush
  rotate_retune_log 2>/dev/null || true
  cleanup_temps quiet 2>/dev/null || true
}

detect_cmd(){
  # Prefer not requiring full tc preflight for detect-only, but root helps for clean tests
  if [[ ${EUID} -ne 0 ]]; then
    warn "Not root: some methods may be less accurate; prefer sudo."
  fi

  echo "====== bandwidth detect v${VERSION} ======"
  echo "Methods: ${DETECT_METHODS}  rounds=${DETECT_ROUNDS}  mode=${AGGREGATE_MODE}"
  echo "Safety factor: ${BANDWIDTH_SAFETY_FACTOR}"
  echo "This will saturate the link for a while. Prefer off-peak on production nodes."
  echo

  if is_tty && [[ "${AUTO_CONFIRM_PEAK}" != "1" ]]; then
    printf '[?] Start multi-method speed tests now? [Y/n] '
    local ans=""
    read -r ans || true
    case "${ans}" in
      n|N|no|NO) die "Detect cancelled." ;;
    esac
  fi

  run_all_detect_methods
  aggregate_peaks
  print_detect_table
  resolve_cake_rtt
  log "CAKE_RTT=${CAKE_RTT}"

  if [[ -z "${PEAK_UP_MBIT:-}" && -z "${PEAK_DOWN_MBIT:-}" ]]; then
    warn "All methods failed or were skipped. Install speedtest-cli / set IPERF3_SERVER / fix HTTP URLs."
    post_detect_housekeeping
    exit 2
  fi

  save_detect_cache

  if [[ "${AUTO_CONFIRM_PEAK}" == "1" ]]; then
    accept_suggest_rates
  elif is_tty; then
    confirm_peak_rates
    if [[ "${BANDWIDTH_SOURCE}" == "detect" ]]; then
      SUGGEST_UP="${BANDWIDTH_UP_DEFAULT}"
      SUGGEST_DOWN="${BANDWIDTH_DOWN_DEFAULT}"
      PEAK_UP_MBIT="$(rate_to_mbit "${BANDWIDTH_UP_DEFAULT}")"
      PEAK_DOWN_MBIT="$(rate_to_mbit "${BANDWIDTH_DOWN_DEFAULT}")"
      mkdir -p "$(dirname "${DETECT_CACHE_FILE}")"
      cat >"${DETECT_CACHE_FILE}" <<EOF
# confirmed by user $(date -Is 2>/dev/null || date)
PEAK_UP_MBIT="${PEAK_UP_MBIT:-}"
PEAK_DOWN_MBIT="${PEAK_DOWN_MBIT:-}"
SUGGEST_UP="${BANDWIDTH_UP_DEFAULT:-}"
SUGGEST_DOWN="${BANDWIDTH_DOWN_DEFAULT:-}"
BANDWIDTH_SAFETY_FACTOR="${BANDWIDTH_SAFETY_FACTOR}"
BANDWIDTH_SOURCE="detect"
DETECT_METHODS="${DETECT_METHODS}"
EOF
    fi
  fi

  post_detect_housekeeping

  echo
  ok "Detect done. 一键应用+安装请执行: $0 auto"
  echo "  或: UP_RATE=${BANDWIDTH_UP_DEFAULT:-${SUGGEST_UP:-}} DOWN_RATE=${BANDWIDTH_DOWN_DEFAULT:-${SUGGEST_DOWN:-}} $0 apply"
}

apply_cmd(){
  require_root
  load_overrides
  preflight
  resolve_bandwidth
  resolve_cake_rtt
  maybe_adjust_ingress_for_cpu
  write_sysctl
  detect_cake_nat
  discover_candidates
  apply_qdisc
  apply_mss
  show_qdisc_status
  echo
  ok "Applied BBR + CAKE profile (source=${BANDWIDTH_SOURCE}, limits=${ENABLE_LIMITS})."
  echo "[NOTE] Use '$0 install' to make tc qdisc and MSS rules persistent across reboot."
  echo "[NOTE] Or one-shot: $0 auto | nightly: $0 retune"
}

